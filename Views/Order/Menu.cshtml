@model HungryHub.Models.MenuViewModel
@{
    ViewData["Title"] = Model.Restaurant.Name + " Menu";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<style>
    .menu-hero {
        background: linear-gradient(135deg, #1a1a2e, #e84545);
        border-radius: 20px;
        padding: 28px 32px;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        color: #fff;
    }
    .menu-hero h2 {
        font-size: 1.6rem;
        font-weight: 700;
        margin: 0;
    }
    .menu-hero .meta {
        font-size: 0.85rem;
        opacity: .8;
        margin-top: 6px;
    }
    .menu-hero .badge-open {
        background: rgba(255,255,255,0.2);
        border: 1px solid rgba(255,255,255,0.4);
        border-radius: 20px;
        padding: 4px 14px;
        font-size: 0.8rem;
        font-weight: 600;
    }

    .cat-tabs {
        display: flex;
        gap: 10px;
        overflow-x: auto;
        padding-bottom: 8px;
        margin-bottom: 24px;
        scrollbar-width: none;
    }
    .cat-tabs::-webkit-scrollbar { display: none; }

    .cat-tab {
        padding: 8px 18px;
        border-radius: 20px;
        border: 1.5px solid var(--border);
        background: #fff;
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        white-space: nowrap;
        transition: all 0.2s;
        color: var(--text);
        font-family: 'Poppins', sans-serif;
    }
    .cat-tab:hover,
    .cat-tab.active {
        background: var(--primary);
        border-color: var(--primary);
        color: #fff;
    }

    .menu-layout {
        display: grid;
        grid-template-columns: 1fr 340px;
        gap: 24px;
    }
    @@media (max-width: 900px) {
        .menu-layout { grid-template-columns: 1fr; }
    }

    .menu-section-title {
        font-size: 1rem;
        font-weight: 700;
        color: var(--text);
        margin: 20px 0 12px;
        padding-left: 12px;
        border-left: 3px solid var(--primary);
    }

    .menu-item-card {
        background: #fff;
        border-radius: 14px;
        padding: 16px;
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 12px;
        box-shadow: var(--shadow);
        transition: transform 0.2s;
    }
    .menu-item-card:hover { transform: translateX(4px); }

    .item-icon {
        font-size: 2.4rem;
        width: 56px;
        text-align: center;
        flex-shrink: 0;
    }
    .item-info  { flex: 1; }
    .item-name  { font-weight: 700; font-size: 0.95rem; color: var(--text); }
    .item-desc  { font-size: 0.78rem; color: var(--muted); margin-top: 2px; }
    .item-price { font-size: 1rem; font-weight: 700; color: var(--primary); margin-top: 4px; }
    .unavailable { opacity: 0.5; pointer-events: none; }

    .qty-control {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-shrink: 0;
    }
    .qty-btn {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        border: none;
        font-size: 1.1rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.15s;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Poppins', sans-serif;
    }
    .qty-btn-minus { background: #f4f6fb; color: #555; }
    .qty-btn-minus:hover { background: #ffc9c9; color: var(--primary); }
    .qty-btn-plus  { background: var(--primary); color: #fff; }
    .qty-btn-plus:hover { background: var(--primary-dk); }

    .qty-display {
        min-width: 24px;
        text-align: center;
        font-weight: 700;
        font-size: 0.95rem;
    }

    /* ── Sticky Cart Panel ───────────────────── */
    .cart-panel {
        position: sticky;
        top: calc(var(--topbar-h) + 16px);
        background: #fff;
        border-radius: 20px;
        box-shadow: var(--shadow);
        overflow: hidden;
        max-height: calc(100vh - 100px);
        display: flex;
        flex-direction: column;
    }
    .cart-header {
        background: linear-gradient(135deg, #1a1a2e, #333);
        color: #fff;
        padding: 16px 20px;
        font-weight: 700;
        font-size: 1rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .cart-body {
        flex: 1;
        overflow-y: auto;
        padding: 16px;
    }
    .cart-empty {
        text-align: center;
        padding: 40px 20px;
        color: var(--muted);
    }
    .cart-empty .big-e { font-size: 2.5rem; }

    .cart-line {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 0;
        border-bottom: 1px solid var(--border);
        font-size: 0.85rem;
    }
    .cart-line:last-child { border-bottom: none; }
    .cart-line-icon  { font-size: 1.3rem; }
    .cart-line-name  { flex: 1; font-weight: 500; color: var(--text); }
    .cart-line-qty   { color: var(--muted); font-size: 0.78rem; }
    .cart-line-price { font-weight: 700; color: var(--primary); }
    .cart-line-remove {
        background: none;
        border: none;
        cursor: pointer;
        color: #ccc;
        font-size: 0.85rem;
        font-weight: 700;
        transition: color 0.2s;
        padding: 2px 6px;
        font-family: 'Poppins', sans-serif;
    }
    .cart-line-remove:hover { color: var(--primary); }

    .cart-footer {
        padding: 16px;
        border-top: 1px solid var(--border);
    }
    .total-row {
        display: flex;
        justify-content: space-between;
        font-size: 0.85rem;
        color: var(--muted);
        margin-bottom: 6px;
    }
    .grand-row {
        display: flex;
        justify-content: space-between;
        font-size: 1rem;
        font-weight: 700;
        color: var(--text);
        margin: 10px 0;
        padding-top: 8px;
        border-top: 2px solid var(--border);
    }
    .btn-checkout {
        width: 100%;
        background: var(--primary);
        color: #fff;
        border: none;
        border-radius: 12px;
        padding: 13px;
        font-size: 0.95rem;
        font-weight: 700;
        cursor: pointer;
        transition: background 0.2s;
        margin-top: 8px;
        text-decoration: none;
        display: block;
        text-align: center;
        font-family: 'Poppins', sans-serif;
    }
    .btn-checkout:hover { background: var(--primary-dk); color: #fff; }
</style>

<!-- Restaurant Hero -->
<div class="menu-hero">
    <div>
        <div style="font-size:0.8rem; opacity:.7; margin-bottom:6px;">
            <a href="/Dashboard"
               style="color:rgba(255,255,255,.7); text-decoration:none;">
                Dashboard
            </a>
            &rarr; @Model.Restaurant.Name
        </div>
        <h2>@Model.Restaurant.ImageUrl @Model.Restaurant.Name</h2>
        <div class="meta">
            @Model.Restaurant.Cuisine &bull;
            &#11088; @Model.Restaurant.Rating &bull;
            @Model.Restaurant.DeliveryTime min &bull;
            Delivery: &#2547;@Model.Restaurant.DeliveryFee.ToString("0")
        </div>
    </div>
    <div>
        <span class="badge-open">
            @(Model.Restaurant.IsOpen ? "Open Now" : "Closed")
        </span>
    </div>
</div>

<!-- Category Tabs -->
<div class="cat-tabs" id="catTabs">
    <button class="cat-tab active"
            onclick="filterCategory('all', this)">
        All Items
    </button>
    @foreach (var cat in Model.Categories)
    {
        <button class="cat-tab"
                onclick="filterCategory('@cat', this)">
            @cat
        </button>
    }
</div>

<div class="menu-layout">

    <!-- Left: Menu Items -->
    <div id="menuList">
        @foreach (var cat in Model.Categories)
        {
            <div class="menu-category" data-cat="@cat">
                <div class="menu-section-title">@cat</div>

                @foreach (var item in Model.MenuItems.Where(m => m.Category == cat))
                {
                    <div class="menu-item-card @(!item.IsAvailable ? "unavailable" : "")"
                         data-cat="@cat"
                         id="card-@item.MenuItemId">

                        <div class="item-icon">@item.Icon</div>

                        <div class="item-info">
                            <div class="item-name">@item.Name</div>
                            <div class="item-desc">@item.Description</div>
                            <div class="item-price">
                                &#2547;@item.Price.ToString("0")
                            </div>
                        </div>

                        <div class="qty-control">
                            <button class="qty-btn qty-btn-minus"
                                    onclick="changeQty(@item.MenuItemId,
                                             '@Html.Raw(item.Name.Replace("'", "\\'"))',
                                             @item.Price,
                                             '@Html.Raw(item.Icon)',
                                             @Model.Restaurant.RestaurantId,
                                             -1)">
                                &#8722;
                            </button>
                            <span class="qty-display"
                                  id="qty-@item.MenuItemId">0</span>
                            <button class="qty-btn qty-btn-plus"
                                    onclick="changeQty(@item.MenuItemId,
                                             '@Html.Raw(item.Name.Replace("'", "\\'"))',
                                             @item.Price,
                                             '@Html.Raw(item.Icon)',
                                             @Model.Restaurant.RestaurantId,
                                             1)">
                                &#43;
                            </button>
                        </div>

                    </div>
                }
            </div>
        }
    </div>

    <!-- Right: Sticky Cart Panel -->
    <div class="cart-panel">
        <div class="cart-header">
            Cart
            <span id="cartCount"
                  style="background:var(--primary); border-radius:20px;
                         padding:2px 10px; font-size:0.78rem;">
                0 items
            </span>
        </div>

        <div class="cart-body" id="cartBody">
            <div class="cart-empty" id="cartEmpty">
                <div class="big-e">&#128722;</div>
                <div style="font-weight:600; margin-top:8px;">
                    Your cart is empty
                </div>
                <div style="font-size:0.8rem; margin-top:4px;">
                    Add items to get started!
                </div>
            </div>
            <div id="cartLines"></div>
        </div>

        <div class="cart-footer" id="cartFooter" style="display:none;">
            <div class="total-row">
                <span>Subtotal</span>
                <span id="subtotalAmt">0</span>
            </div>
            <div class="total-row">
                <span>Delivery fee</span>
                <span>&#2547;@Model.Restaurant.DeliveryFee.ToString("0")</span>
            </div>
            <div class="grand-row">
                <span>Grand Total</span>
                <span id="grandTotalAmt">0</span>
            </div>
            <a asp-controller="Cart"
                asp-action="Index"
                class="btn-checkout">
                 Proceed to Checkout →
            </a>
        </div>
    </div>

</div>

@section Scripts {
<script>
    let cart = {};
    const deliveryFee    = @Model.Restaurant.DeliveryFee;
    const taka           = '\u09F3'; // Bengali Taka sign ৳

    function changeQty(id, name, price, icon, restId, delta) {
        if (!cart[id]) {
            cart[id] = { id: id, name: name, price: price,
                         icon: icon, restId: restId, qty: 0 };
        }

        cart[id].qty = Math.max(0, cart[id].qty + delta);
        if (cart[id].qty === 0) delete cart[id];

        var qtyEl = document.getElementById('qty-' + id);
        if (qtyEl) {
            qtyEl.textContent = cart[id] ? cart[id].qty : 0;
        }

        var endpoint = delta > 0 ? '/Order/AddToCart' : '/Order/RemoveFromCart';

        if (delta > 0) {
            fetch(endpoint, {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'menuItemId=' + id
                    + '&itemName=' + encodeURIComponent(name)
                    + '&unitPrice=' + price
                    + '&icon='     + encodeURIComponent(icon)
                    + '&restaurantId=' + restId
            });
        } else {
            fetch(endpoint, {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'menuItemId=' + id
            });
        }

        renderCart();
    }

    function renderCart() {
        var lines  = document.getElementById('cartLines');
        var empty  = document.getElementById('cartEmpty');
        var footer = document.getElementById('cartFooter');
        var count  = document.getElementById('cartCount');

        var items    = Object.values(cart);
        var totalQty = items.reduce(function(s, i) { return s + i.qty; }, 0);
        var subtotal = items.reduce(function(s, i) {
            return s + (i.qty * i.price);
        }, 0);
        var grand = subtotal + deliveryFee;

        count.textContent = totalQty + (totalQty !== 1 ? ' items' : ' item');

        if (items.length === 0) {
            empty.style.display  = 'block';
            lines.innerHTML      = '';
            footer.style.display = 'none';
            return;
        }

        empty.style.display  = 'none';
        footer.style.display = 'block';

        var html = '';
        for (var idx = 0; idx < items.length; idx++) {
            var i = items[idx];
            html += '<div class="cart-line">'
                  +   '<span class="cart-line-icon">' + i.icon + '</span>'
                  +   '<span class="cart-line-name">' + i.name + '</span>'
                  +   '<span class="cart-line-qty">x' + i.qty + '</span>'
                  +   '<span class="cart-line-price">'
                  +       taka + (i.qty * i.price).toFixed(0)
                  +   '</span>'
                  +   '<button class="cart-line-remove" '
                  +       'onclick="removeAll(' + i.id + ')">X</button>'
                  + '</div>';
        }
        lines.innerHTML = html;

        document.getElementById('subtotalAmt').textContent =
            taka + subtotal.toFixed(0);
        document.getElementById('grandTotalAmt').textContent =
            taka + grand.toFixed(0);
    }

    function removeAll(id) {
        if (!cart[id]) return;
        var qty = cart[id].qty;
        for (var i = 0; i < qty; i++) {
            fetch('/Order/RemoveFromCart', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'menuItemId=' + id
            });
        }
        delete cart[id];
        var qtyEl = document.getElementById('qty-' + id);
        if (qtyEl) qtyEl.textContent = 0;
        renderCart();
    }

    function filterCategory(cat, btn) {
        var tabs = document.querySelectorAll('.cat-tab');
        for (var i = 0; i < tabs.length; i++) {
            tabs[i].classList.remove('active');
        }
        btn.classList.add('active');

        var sections = document.querySelectorAll('.menu-category');
        for (var j = 0; j < sections.length; j++) {
            sections[j].style.display =
                (cat === 'all' || sections[j].dataset.cat === cat)
                    ? 'block' : 'none';
        }
    }
</script>
}