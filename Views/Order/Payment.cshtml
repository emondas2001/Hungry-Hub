@model HungryHub.Models.PaymentViewModel
@{
    ViewData["Title"] = "Payment";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewBag.UserFullName = Model.UserFullName;
}

<style>
    .pay-wrap {
        max-width: 680px;
        margin: 0 auto;
    }
    .pay-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: var(--shadow);
        overflow: hidden;
        margin-bottom: 20px;
    }
    .pay-card-header {
        padding: 18px 24px;
        border-bottom: 2px solid var(--border);
        font-size: 1rem;
        font-weight: 700;
        color: var(--text);
    }
    .pay-card-body { padding: 22px 24px; }

    /* Order summary */
    .summary-row {
        display: flex;
        justify-content: space-between;
        font-size: 0.88rem;
        padding: 6px 0;
        color: var(--text);
        border-bottom: 1px solid var(--border);
    }
    .summary-row:last-child { border-bottom: none; }
    .summary-row .lbl { color: var(--muted); }
    .summary-total {
        display: flex;
        justify-content: space-between;
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--text);
        padding-top: 12px;
        margin-top: 4px;
        border-top: 2px solid var(--text);
    }
    .summary-total span:last-child {
        color: var(--primary);
    }

    /* Payment method selector */
    .method-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
        margin-bottom: 22px;
    }
    @@media(max-width:600px) {
        .method-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }
    .method-card {
        border: 2px solid var(--border);
        border-radius: 14px;
        padding: 14px 10px;
        text-align: center;
        cursor: pointer;
        transition: all 0.2s;
        background: #fff;
        position: relative;
    }
    .method-card:hover {
        border-color: var(--primary);
        background: #fff5f5;
    }
    .method-card.selected {
        border-color: var(--primary);
        background: #fff5f5;
    }
    .method-card.selected::after {
        content: '✓';
        position: absolute;
        top: 6px; right: 8px;
        color: var(--primary);
        font-weight: 700;
        font-size: 0.8rem;
    }
    .method-logo {
        font-size: 1.8rem;
        margin-bottom: 6px;
        display: block;
    }
    .method-logo img {
        width: 48px;
        height: 32px;
        object-fit: contain;
    }
    .method-name {
        font-size: 0.83rem;
        font-weight: 700;
        color: var(--text);
    }
    .method-sub {
        font-size: 0.7rem;
        color: var(--muted);
        margin-top: 2px;
    }

    /* Payment fields */
    .pay-field-group {
        display: none;
    }
    .pay-field-group.active {
        display: block;
    }
    .form-label {
        font-size: 0.86rem;
        font-weight: 600;
        color: var(--text);
        margin-bottom: 6px;
    }
    .form-control {
        border-radius: 10px;
        border: 1.5px solid var(--border);
        padding: 11px 14px;
        font-size: 0.9rem;
        width: 100%;
        transition: border-color 0.2s;
        font-family: 'Poppins', sans-serif;
    }
    .form-control:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px
            rgba(232,69,69,0.1);
    }
    .input-prefix-wrap {
        display: flex;
        align-items: center;
        border: 1.5px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
        transition: border-color 0.2s;
    }
    .input-prefix-wrap:focus-within {
        border-color: var(--primary);
        box-shadow: 0 0 0 3px
            rgba(232,69,69,0.1);
    }
    .input-prefix {
        background: #f4f6fb;
        padding: 11px 12px;
        font-size: 0.85rem;
        color: var(--muted);
        font-weight: 600;
        white-space: nowrap;
        border-right: 1.5px solid var(--border);
    }
    .input-prefix-wrap input {
        border: none;
        outline: none;
        padding: 11px 14px;
        font-size: 0.9rem;
        font-family: 'Poppins', sans-serif;
        width: 100%;
    }
    .card-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }

    /* Method color badges */
    .badge-bkash    { color: #E2136E; }
    .badge-nagad    { color: #F7941D; }
    .badge-rocket   { color: #8B2FC9; }
    .badge-visa     { color: #1A1F71; }
    .badge-master   { color: #EB001B; }
    .badge-cash     { color: #1D7044; }

    /* Pay button */
    .btn-pay {
        width: 100%;
        background: var(--primary);
        color: #fff;
        border: none;
        border-radius: 14px;
        padding: 15px;
        font-size: 1rem;
        font-weight: 700;
        cursor: pointer;
        transition: background 0.2s,
                    transform 0.1s;
        font-family: 'Poppins', sans-serif;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }
    .btn-pay:hover {
        background: var(--primary-dk);
        transform: translateY(-1px);
    }
    .btn-pay:active { transform: translateY(0); }
    .btn-pay:disabled {
        background: #ccc;
        cursor: not-allowed;
        transform: none;
    }

    /* Processing overlay */
    .processing-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.5);
        z-index: 9999;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        gap: 16px;
    }
    .processing-overlay.show {
        display: flex;
    }
    .processing-box {
        background: #fff;
        border-radius: 20px;
        padding: 36px 48px;
        text-align: center;
        box-shadow: 0 8px 40px rgba(0,0,0,0.2);
    }
    .spinner {
        width: 50px; height: 50px;
        border: 4px solid #f0f0f0;
        border-top: 4px solid var(--primary);
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
        margin: 0 auto 14px;
    }
    @@keyframes spin {
        to { transform: rotate(360deg); }
    }
    .processing-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 6px;
    }
    .processing-sub {
        font-size: 0.85rem;
        color: var(--muted);
    }

    /* Security note */
    .security-note {
        display: flex;
        align-items: center;
        gap: 8px;
        background: #f0fff4;
        border: 1px solid #c3e6cb;
        border-radius: 10px;
        padding: 10px 14px;
        font-size: 0.8rem;
        color: #1d7044;
        margin-top: 14px;
    }
</style>

<!-- Processing overlay -->
<div class="processing-overlay"
     id="processingOverlay">
    <div class="processing-box">
        <div class="spinner"></div>
        <div class="processing-title"
             id="processingTitle">
            Processing Payment...
        </div>
        <div class="processing-sub">
            Please do not close this page
        </div>
    </div>
</div>

<div class="pay-wrap">

    <!-- Page title -->
    <div style="margin-bottom:20px;">
        <div style="font-size:1.4rem;
                    font-weight:700;
                    color:var(--text);">
            💳 Payment
        </div>
        <div style="color:var(--muted);
                    font-size:0.9rem;
                    margin-top:2px;">
            Complete your order from
            @Model.RestaurantName
        </div>
    </div>

    <!-- Validation errors -->
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger
                    alert-dismissible fade show"
             style="border-radius:12px;
                    border:none;
                    margin-bottom:16px;">
            @foreach (var state in
                ViewData.ModelState.Values)
            {
                foreach (var err in state.Errors)
                {
                    <div>⚠️ @err.ErrorMessage</div>
                }
            }
            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert">
            </button>
        </div>
    }

    <form asp-controller="Order"
          asp-action="ProcessPayment"
          method="post"
          id="paymentForm">
        @Html.AntiForgeryToken()
        <input type="hidden"
               name="OrderId"
               value="@Model.OrderId"/>
        <input type="hidden"
               name="Amount"
               value="@Model.Amount"/>
        <input type="hidden"
               name="RestaurantName"
               value="@Model.RestaurantName"/>
        <input type="hidden"
               name="UserFullName"
               value="@Model.UserFullName"/>
        <input type="hidden"
               name="UserEmail"
               value="@Model.UserEmail"/>
        <input type="hidden"
               name="PaymentMethod"
               id="selectedMethod"
               value=""/>

        <!-- Order summary -->
        <div class="pay-card">
            <div class="pay-card-header">
                📋 Order Summary
            </div>
            <div class="pay-card-body">
                <div class="summary-row">
                    <span class="lbl">Restaurant</span>
                    <span>@Model.RestaurantName</span>
                </div>
                <div class="summary-row">
                    <span class="lbl">Order #</span>
                    <span style="font-weight:600;">
                        #@Model.OrderId
                    </span>
                </div>
                <div class="summary-row">
                    <span class="lbl">Customer</span>
                    <span>@Model.UserFullName</span>
                </div>
                <div class="summary-total">
                    <span>Total to Pay</span>
                    <span>
                        &#2547;@Model.Amount
                            .ToString("N0")
                    </span>
                </div>
            </div>
        </div>

        <!-- Payment method selection -->
        <div class="pay-card">
            <div class="pay-card-header">
                Select Payment Method
            </div>
            <div class="pay-card-body">

                <div class="method-grid">

                    <!-- bKash -->
                    <div class="method-card"
                         id="card-bKash"
                         onclick="selectMethod(
                             'bKash',
                             'mobile-fields',
                             'bKash')">
                        <span class="method-logo
                                     badge-bkash">
                            📱
                        </span>
                        <div class="method-name
                                    badge-bkash">
                            bKash
                        </div>
                        <div class="method-sub">
                            Mobile Banking
                        </div>
                    </div>

                    <!-- Nagad -->
                    <div class="method-card"
                         id="card-Nagad"
                         onclick="selectMethod(
                             'Nagad',
                             'mobile-fields',
                             'Nagad')">
                        <span class="method-logo
                                     badge-nagad">
                            📲
                        </span>
                        <div class="method-name
                                    badge-nagad">
                            Nagad
                        </div>
                        <div class="method-sub">
                            Mobile Banking
                        </div>
                    </div>

                    <!-- Rocket -->
                    <div class="method-card"
                         id="card-Rocket"
                         onclick="selectMethod(
                             'Rocket',
                             'mobile-fields',
                             'Rocket')">
                        <span class="method-logo
                                     badge-rocket">
                            🚀
                        </span>
                        <div class="method-name
                                    badge-rocket">
                            Rocket
                        </div>
                        <div class="method-sub">
                            DBBL Mobile
                        </div>
                    </div>

                    <!-- Visa -->
                    <div class="method-card"
                         id="card-Visa"
                         onclick="selectMethod(
                             'Visa',
                             'card-fields',
                             'Visa')">
                        <span class="method-logo">
                            💳
                        </span>
                        <div class="method-name
                                    badge-visa">
                            Visa
                        </div>
                        <div class="method-sub">
                            Debit / Credit
                        </div>
                    </div>

                    <!-- Mastercard -->
                    <div class="method-card"
                         id="card-Mastercard"
                         onclick="selectMethod(
                             'Mastercard',
                             'card-fields',
                             'Mastercard')">
                        <span class="method-logo">
                            💳
                        </span>
                        <div class="method-name
                                    badge-master">
                            Mastercard
                        </div>
                        <div class="method-sub">
                            Debit / Credit
                        </div>
                    </div>

                    <!-- Cash -->
                    <div class="method-card"
                         id="card-Cash"
                         onclick="selectMethod(
                             'Cash',
                             'cash-fields',
                             'Cash')">
                        <span class="method-logo
                                     badge-cash">
                            💵
                        </span>
                        <div class="method-name
                                    badge-cash">
                            Cash
                        </div>
                        <div class="method-sub">
                            On Delivery
                        </div>
                    </div>

                </div>

                <!-- Mobile banking fields -->
                <div class="pay-field-group"
                     id="mobile-fields">
                    <div class="mb-3">
                        <label class="form-label">
                            <span id="mobileMethodLabel">
                                bKash
                            </span>
                            Account Number *
                        </label>
                        <div class="input-prefix-wrap">
                            <span class="input-prefix">
                                +880
                            </span>
                            <input type="tel"
                                   name="MobileNumber"
                                   id="mobileInput"
                                   placeholder="1XXXXXXXXX"
                                   maxlength="10"
                                   oninput="formatMobile(this)"/>
                        </div>
                        <div style="font-size:0.75rem;
                                    color:var(--muted);
                                    margin-top:4px;">
                            Enter your registered
                            mobile number
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">
                            PIN *
                        </label>
                        <input type="password"
                               name="MobilePin"
                               class="form-control"
                               placeholder="Enter your PIN"
                               maxlength="6"/>
                        <div style="font-size:0.75rem;
                                    color:var(--muted);
                                    margin-top:4px;">
                            Your mobile banking PIN
                        </div>
                    </div>
                    <div style="background:#f8f9ff;
                                border-radius:10px;
                                padding:12px 14px;
                                font-size:0.82rem;
                                color:var(--muted);">
                        <strong style="color:var(--text);">
                            How it works:
                        </strong>
                        Enter your mobile number and
                        PIN. A confirmation request
                        will be sent to your phone.
                    </div>
                </div>

                <!-- Card fields -->
                <div class="pay-field-group"
                     id="card-fields">
                    <div class="mb-3">
                        <label class="form-label">
                            Card Number *
                        </label>
                        <input type="text"
                               name="CardNumber"
                               class="form-control"
                               placeholder="XXXX XXXX XXXX XXXX"
                               maxlength="19"
                               oninput="formatCard(this)"/>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">
                            Cardholder Name *
                        </label>
                        <input type="text"
                               name="CardHolder"
                               class="form-control"
                               placeholder="Name on card"
                               style="text-transform:uppercase;"/>
                    </div>
                    <div class="card-row mb-3">
                        <div>
                            <label class="form-label">
                                Expiry Date *
                            </label>
                            <input type="text"
                                   name="CardExpiry"
                                   class="form-control"
                                   placeholder="MM/YY"
                                   maxlength="5"
                                   oninput="formatExpiry(this)"/>
                        </div>
                        <div>
                            <label class="form-label">
                                CVV *
                            </label>
                            <input type="password"
                                   name="CardCVV"
                                   class="form-control"
                                   placeholder="CVV"
                                   maxlength="4"/>
                        </div>
                    </div>
                    <div style="background:#f0f4ff;
                                border-radius:10px;
                                padding:12px 14px;
                                font-size:0.82rem;
                                color:var(--muted);">
                        🔒 Your card details are
                        encrypted and secure.
                        We never store full card numbers.
                    </div>
                </div>

                <!-- Cash fields -->
                <div class="pay-field-group"
                     id="cash-fields">
                    <div style="background:#f0fff4;
                                border:1.5px solid
                                    #c3e6cb;
                                border-radius:12px;
                                padding:18px;
                                text-align:center;">
                        <div style="font-size:2rem;
                                    margin-bottom:8px;">
                            💵
                        </div>
                        <div style="font-weight:700;
                                    font-size:1rem;
                                    color:#1d7044;
                                    margin-bottom:6px;">
                            Cash on Delivery
                        </div>
                        <div style="font-size:0.85rem;
                                    color:#555;">
                            Please prepare exactly
                            <strong>
                                &#2547;@Model.Amount
                                    .ToString("N0")
                            </strong>
                            when the rider arrives.
                        </div>
                    </div>
                </div>

            </div>
        </div>

        <!-- Pay button -->
        <button type="submit"
                class="btn-pay"
                id="payBtn"
                disabled>
            <span id="payBtnIcon">🔒</span>
            <span id="payBtnText">
                Select a payment method
            </span>
        </button>

        <div class="security-note">
            🔐 All transactions are secured with
            256-bit SSL encryption.
            Your payment information is safe.
        </div>

    </form>
</div>

@section Scripts {
<script>
    var currentMethod = '';

    function selectMethod(
        method, fieldsId, cardId) {

        // Deselect all cards
        document.querySelectorAll('.method-card')
            .forEach(function(c) {
                c.classList.remove('selected');
            });

        // Hide all field groups
        document.querySelectorAll(
            '.pay-field-group')
            .forEach(function(f) {
                f.classList.remove('active');
            });

        // Select clicked card
        var card = document.getElementById(
            'card-' + cardId);
        if (card) card.classList.add('selected');

        // Show relevant fields
        var fields = document.getElementById(
            fieldsId);
        if (fields) fields.classList.add('active');

        // Update hidden input
        currentMethod = method;
        document.getElementById('selectedMethod')
            .value = method;

        // Update mobile label
        var lbl = document.getElementById(
            'mobileMethodLabel');
        if (lbl) lbl.textContent = method;

        // Enable pay button
        var btn = document.getElementById('payBtn');
        var txt = document.getElementById(
            'payBtnText');
        btn.disabled = false;
        txt.textContent =
            'Pay ৳' +
            '@Model.Amount.ToString("N0")' +
            ' via ' + method;

        // Update button color
        var colors = {
            'bKash':      '#E2136E',
            'Nagad':      '#F7941D',
            'Rocket':     '#8B2FC9',
            'Visa':       '#1A1F71',
            'Mastercard': '#EB001B',
            'Cash':       '#1D7044'
        };
        btn.style.background =
            colors[method] || 'var(--primary)';
    }

    // Format card number with spaces
    function formatCard(input) {
        var v = input.value
            .replace(/\D/g, '')
            .substring(0, 16);
        var parts = [];
        for (var i = 0; i < v.length; i += 4) {
            parts.push(v.substring(i, i + 4));
        }
        input.value = parts.join(' ');
    }

    // Format expiry MM/YY
    function formatExpiry(input) {
        var v = input.value
            .replace(/\D/g, '')
            .substring(0, 4);
        if (v.length >= 3) {
            input.value =
                v.substring(0, 2) + '/' +
                v.substring(2);
        } else {
            input.value = v;
        }
    }

    // Format mobile number
    function formatMobile(input) {
        input.value = input.value
            .replace(/\D/g, '')
            .substring(0, 10);
    }

    // Show processing overlay on submit
    document.getElementById('paymentForm')
        .addEventListener('submit', function(e) {
            if (!currentMethod) {
                e.preventDefault();
                return;
            }

            var titles = {
                'bKash':      'Processing bKash Payment...',
                'Nagad':      'Processing Nagad Payment...',
                'Rocket':     'Processing Rocket Payment...',
                'Visa':       'Verifying Card...',
                'Mastercard': 'Verifying Card...',
                'Cash':       'Confirming Order...'
            };

            var overlay = document.getElementById(
                'processingOverlay');
            var title = document.getElementById(
                'processingTitle');

            title.textContent =
                titles[currentMethod] ||
                'Processing...';
            overlay.classList.add('show');

            document.getElementById('payBtn')
                .disabled = true;
        });
</script>
}