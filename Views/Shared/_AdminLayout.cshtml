<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] — HungryHub Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
          rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap"
          rel="stylesheet" />
    <style>
            :root {
                --primary:    #e84545;
                --primary-dk: #c73535;
                --sidebar-w:  250px;
                --topbar-h:   64px;
                --bg:         #f0f2f8;
                --card-bg:    #ffffff;
                --text:       #1a1a2e;
                --muted:      #8a8fa8;
                --border:     #eaecf3;
                --shadow:     0 2px 16px rgba(0,0,0,0.07);
                --admin-dark: #0f0f1f;
                --admin-side: #161625;
            }

            * { box-sizing:border-box; margin:0; padding:0; }

            body {
                font-family:'Poppins',sans-serif;
                background:var(--bg);
                color:var(--text);
            }

            /* ── Sidebar ── */
            .admin-sidebar {
                position:fixed; top:0; left:0;
                width:var(--sidebar-w);
                height:100vh;
                background:var(--admin-side);
                display:flex; flex-direction:column;
                z-index:100;
            }

            .admin-brand {
                padding:18px 20px;
                border-bottom:1px solid rgba(255,255,255,0.07);
                display:flex; align-items:center; gap:10px;
            }

            .admin-brand .logo-text {
                font-size:1.15rem;
                font-weight:700;
                color:#fff;
            }

            .admin-brand .logo-text span { color:var(--primary); }

            .admin-badge {
                background:var(--primary);
                color:#fff;
                border-radius:6px;
                padding:2px 8px;
                font-size:0.68rem;
                font-weight:700;
                letter-spacing:0.5px;
                margin-left:4px;
            }

            .admin-nav {
                flex:1; padding:14px 10px;
                overflow-y:auto;
            }

            .nav-section-label {
                font-size:0.67rem;
                font-weight:600;
                letter-spacing:1.2px;
                text-transform:uppercase;
                color:rgba(255,255,255,0.28);
                padding:10px 12px 5px;
            }

            .admin-nav-item a {
                display:flex; align-items:center;
                gap:11px; padding:10px 13px;
                border-radius:10px;
                color:rgba(255,255,255,0.6);
                text-decoration:none;
                font-size:0.875rem;
                font-weight:500;
                transition:all 0.2s;
                margin-bottom:2px;
            }

            .admin-nav-item a:hover,
            .admin-nav-item a.active {
                background:rgba(232,69,69,0.18);
                color:#fff;
            }

            .admin-nav-item a.active { color:var(--primary); }
            .nav-icon { font-size:1.05rem; width:20px; text-align:center; }

            .sidebar-footer {
                padding:14px 10px;
                border-top:1px solid rgba(255,255,255,0.07);
            }

            .sidebar-footer a {
                display:flex; align-items:center;
                gap:10px; padding:10px 13px;
                border-radius:10px;
                color:rgba(255,255,255,0.45);
                text-decoration:none;
                font-size:0.85rem;
                transition:all 0.2s;
            }

            .sidebar-footer a:hover {
                background:rgba(232,69,69,0.15);
                color:var(--primary);
            }

            /* ── Topbar ── */
            .admin-topbar {
                position:fixed;
                top:0; left:var(--sidebar-w); right:0;
                height:var(--topbar-h);
                background:var(--card-bg);
                border-bottom:1px solid var(--border);
                display:flex; align-items:center;
                padding:0 28px; gap:16px;
                z-index:99;
                box-shadow:var(--shadow);
            }

            .topbar-title {
                font-size:1.1rem;
                font-weight:700;
                color:var(--text);
                flex:1;
            }

            .topbar-stats {
                display:flex; gap:20px;
                align-items:center;
            }

            .topbar-stat {
                display:flex; flex-direction:column;
                align-items:center;
                font-size:0.72rem;
                color:var(--muted);
            }

            .topbar-stat .val {
                font-size:0.95rem;
                font-weight:700;
                color:var(--text);
            }

            .admin-pill {
                display:flex; align-items:center;
                gap:10px; padding:6px 14px 6px 6px;
                border-radius:40px;
                border:1.5px solid var(--border);
                background:var(--bg);
                cursor:default;
            }

            .admin-avatar {
                width:30px; height:30px;
                border-radius:50%;
                background:var(--primary);
                color:#fff;
                display:flex; align-items:center;
                justify-content:center;
                font-size:0.8rem;
                font-weight:700;
            }

            .admin-name {
                font-size:0.85rem;
                font-weight:600;
                color:var(--text);
            }

            /* ── Main content ── */
            .admin-main {
                margin-left:var(--sidebar-w);
                margin-top:var(--topbar-h);
                padding:28px;
                min-height:calc(100vh - var(--topbar-h));
            }

            /* ── Stat cards ── */
            .stat-grid {
                display:grid;
                grid-template-columns:repeat(auto-fit, minmax(180px,1fr));
                gap:16px;
                margin-bottom:24px;
            }

            .stat-card {
                background:var(--card-bg);
                border-radius:16px;
                padding:20px;
                box-shadow:var(--shadow);
                display:flex; align-items:center;
                gap:14px;
                transition:transform 0.2s;
            }

            .stat-card:hover { transform:translateY(-3px); }

            .stat-icon {
                width:48px; height:48px;
                border-radius:14px;
                display:flex; align-items:center;
                justify-content:center;
                font-size:1.4rem;
                flex-shrink:0;
            }

            .stat-label {
                font-size:0.75rem;
                color:var(--muted);
                font-weight:500;
            }

            .stat-value {
                font-size:1.5rem;
                font-weight:700;
                color:var(--text);
                line-height:1.2;
            }

            /* ── Tables ── */
            .admin-table-card {
                background:var(--card-bg);
                border-radius:16px;
                box-shadow:var(--shadow);
                overflow:hidden;
                margin-bottom:24px;
            }

            .admin-table-header {
                display:flex; align-items:center;
                justify-content:space-between;
                padding:18px 22px;
                border-bottom:1px solid var(--border);
            }

            .admin-table-title {
                font-size:1rem;
                font-weight:700;
                color:var(--text);
            }

            table { width:100%; border-collapse:collapse; }

            thead th {
                background:#f8f9ff;
                padding:12px 16px;
                font-size:0.78rem;
                font-weight:700;
                color:var(--muted);
                text-transform:uppercase;
                letter-spacing:0.5px;
                text-align:left;
                border-bottom:1px solid var(--border);
            }

            tbody td {
                padding:13px 16px;
                font-size:0.85rem;
                color:var(--text);
                border-bottom:1px solid var(--border);
                vertical-align:middle;
            }

            tbody tr:last-child td { border-bottom:none; }

            tbody tr:hover { background:#fafbff; }

            .status-badge {
                padding:4px 12px;
                border-radius:20px;
                font-size:0.73rem;
                font-weight:700;
            }

            .s-confirmed { background:#e8f9ee; color:#1d7044; }
            .s-delivered { background:#e3f2fd; color:#1565c0; }
            .s-cancelled { background:#fdecea; color:#c62828; }
            .s-pending   { background:#fff8e1; color:#e65100; }

            /* ── Buttons ── */
            .btn-admin {
                background:var(--primary);
                color:#fff; border:none;
                border-radius:8px;
                padding:7px 16px;
                font-size:0.83rem;
                font-weight:600;
                cursor:pointer;
                transition:background 0.2s;
                text-decoration:none;
                display:inline-block;
                font-family:'Poppins',sans-serif;
            }

            .btn-admin:hover {
                background:var(--primary-dk);
                color:#fff;
            }

            .btn-danger-sm {
                background:#fdecea;
                border:1px solid #f5c6c6;
                border-radius:8px;
                padding:5px 12px;
                font-size:0.78rem;
                font-weight:600;
                color:#c62828;
                cursor:pointer;
                transition:all 0.2s;
                font-family:'Poppins',sans-serif;
            }

            .btn-danger-sm:hover {
                background:#c62828;
                color:#fff;
                border-color:#c62828;
            }

            .btn-success-sm {
                background:#e8f9ee;
                border:1px solid #c3e6cb;
                border-radius:8px;
                padding:5px 12px;
                font-size:0.78rem;
                font-weight:600;
                color:#1d7044;
                cursor:pointer;
                transition:all 0.2s;
                font-family:'Poppins',sans-serif;
            }

            .btn-success-sm:hover {
                background:#1d7044;
                color:#fff;
            }

            .form-control, .form-select {
                border-radius:8px;
                border:1.5px solid var(--border);
                padding:8px 12px;
                font-size:0.875rem;
                font-family:'Poppins',sans-serif;
                transition:border-color 0.2s;
            }

            .form-control:focus, .form-select:focus {
                outline:none;
                border-color:var(--primary);
                box-shadow:0 0 0 3px rgba(232,69,69,0.1);
            }

            .page-heading {
                font-size:1.4rem;
                font-weight:700;
                color:var(--text);
                margin-bottom:4px;
            }

            .page-sub {
                font-size:0.88rem;
                color:var(--muted);
                margin-bottom:20px;
            }
    </style>
</head>
<body>

    <!-- Sidebar -->
    <aside class="admin-sidebar">
        <div class="admin-brand">
            <span style="font-size:1.4rem;">🍔</span>
            <div class="logo-text">
                Hungry<span>Hub</span>
                <span class="admin-badge">ADMIN</span>
            </div>
        </div>

   <nav class="admin-nav">
            <div class="nav-section-label">Main</div>

           <nav class="admin-nav">
    <div class="nav-section-label">Main</div>

    <div class="admin-nav-item">
        <a href="/Admin/Dashboard"
           class="@(ViewContext.RouteData
               .Values["action"]?.ToString()
               == "Dashboard" ? "active" : "")">
            <span class="nav-icon">📊</span>
            Dashboard
        </a>
    </div>

    <div class="admin-nav-item">
        <a href="/Admin/Restaurants"
           class="@(ViewContext.RouteData
               .Values["action"]?.ToString()
               == "Restaurants" ? "active" : "")">
            <span class="nav-icon">🍽️</span>
            Restaurants
        </a>
    </div>

                <div class="admin-nav-item">
                    <a href="/Admin/RestaurantOwners"
                       class="@(ViewContext.RouteData
                                  .Values["action"]?.ToString()
                                  == "RestaurantOwners"
                                  ? "active" : "")">
                        <span class="nav-icon">🏪</span>
                        Restaurant Owners
                    </a>
                </div>

    <div class="admin-nav-item">
        <a href="/Admin/Orders"
           class="@(ViewContext.RouteData
               .Values["action"]?.ToString()
               == "Orders" ? "active" : "")">
            <span class="nav-icon">📦</span>
            Orders
            @if (ViewBag.PendingOrders != null &&
                 (int)ViewBag.PendingOrders > 0)
            {
                <span style="margin-left:auto;
                             background:var(--primary);
                             color:#fff;
                             border-radius:20px;
                             padding:1px 8px;
                             font-size:0.7rem;">
                    @ViewBag.PendingOrders
                </span>
            }
        </a>
    </div>

    <div class="admin-nav-item">
        <a href="/Admin/Users"
           class="@(ViewContext.RouteData
               .Values["action"]?.ToString()
               == "Users" ? "active" : "")">
            <span class="nav-icon">👥</span>
            Users
        </a>
    </div>

    <div class="admin-nav-item">
        <a href="/Admin/MenuItems"
           class="@(ViewContext.RouteData
               .Values["action"]?.ToString()
               == "MenuItems" ? "active" : "")">
            <span class="nav-icon">🧾</span>
            Menu Items
        </a>
    </div>

    <div class="admin-nav-item">
        <a href="/Admin/Ratings"
           class="@(ViewContext.RouteData
               .Values["action"]?.ToString()
               == "Ratings" ? "active" : "")">
            <span class="nav-icon">⭐</span>
            Ratings
        </a>
    </div>

    <div class="nav-section-label"
         style="margin-top:8px;">
        Reports
    </div>

    <div class="admin-nav-item">
        <a href="/Dashboard/DownloadExcel">
            <span class="nav-icon">📊</span>
            Export Excel
        </a>
    </div>

    <div class="admin-nav-item">
        <a href="#"
           onclick="document.getElementById(
               'sendReportForm').submit();">
            <span class="nav-icon">📧</span>
            Send Report Now
        </a>
    </div>

                <div class="nav-section-label"
                     style="margin-top:8px;">
                    Special Features
                </div>

                <div class="admin-nav-item">
                    <a href="/Admin/SplitOrders"
                       class="@(ViewContext.RouteData
                                  .Values["action"]?.ToString()
                                  == "SplitOrders" ? "active" : "")">
                        <span class="nav-icon">💰</span>
                        Split Orders
                    </a>
                </div>

                <div class="admin-nav-item">
                    <a href="/Admin/PreOrders"
                       class="@(ViewContext.RouteData
                                  .Values["action"]?.ToString()
                                  == "PreOrders" ? "active" : "")">
                        <span class="nav-icon">🎉</span>
                        Pre-Orders
                        @{
                            int pendingPreOrders = 0;
                            try
                            {
                                pendingPreOrders =
                                    ViewBag.PendingPreOrders
                                    is int ppo ? ppo : 0;
                            }
                            catch { }
                        }
                        @if (pendingPreOrders > 0)
                        {
                            <span style="margin-left:auto;
                                background:var(--primary);
                                color:#fff;
                                border-radius:20px;
                                padding:1px 8px;
                                font-size:0.7rem;">
                                @pendingPreOrders
                            </span>
                        }
                    </a>
                </div>

                <div class="admin-nav-item">
                    <a href="/Admin/Subscriptions"
                       class="@(ViewContext.RouteData
                                  .Values["action"]?.ToString()
                                  == "Subscriptions" ? "active" : "")">
                        <span class="nav-icon">🍱</span>
                        Subscriptions
                    </a>
                </div>

                <div class="admin-nav-item">
                    <a href="/Admin/Coupons"
                       class="@(ViewContext.RouteData
                                  .Values["action"]?.ToString()
                                  == "Coupons" ? "active" : "")">
                        <span class="nav-icon">🏷️</span>
                        Coupons
                    </a>
                </div>


     </nav>

<!-- Hidden form for send report -->
<form id="sendReportForm"
      asp-controller="Admin"
      asp-action="SendReportNow"
      method="post" style="display:none;">
    @Html.AntiForgeryToken()
</form>

        <div class="sidebar-footer">
            <a href="/Admin/Logout">
                <span>🚪</span> Logout
            </a>
        </div>
    </aside>

    <!-- Topbar -->
    <header class="admin-topbar">
        <div class="topbar-title">@ViewData["Title"]</div>

        <div class="topbar-stats">
            <div class="topbar-stat">
                <span class="val">@ViewBag.TotalUsers</span>
                <span>Users</span>
            </div>
            <div class="topbar-stat">
                <span class="val">@ViewBag.TotalOrders</span>
                <span>Orders</span>
            </div>
            <div class="topbar-stat">
                <span class="val" style="color:var(--primary);">
                    @ViewBag.PendingOrders
                </span>
                <span>Pending</span>
            </div>
        </div>

        <div class="admin-pill">
            <div class="admin-avatar">A</div>
            <span class="admin-name">
                @(ViewBag.AdminFullName?.ToString()?.Split(' ')[0]
                  ?? "Admin")
            </span>
        </div>
    </header>

    <!-- Main Content -->
    <main class="admin-main">
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>