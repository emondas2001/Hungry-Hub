<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport"
          content="width=device-width,
    initial-scale=1" />
    <title>
        @ViewData["Title"] —
        @(ViewBag.OwnerRestaurantName ?? "Restaurant")
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
          rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap"
          rel="stylesheet" />
    <style>
            :root {
                --primary: #e84545;
                --primary-dk: #c73535;
                --sidebar-w: 230px;
                --topbar-h: 60px;
                --bg: #f4f6fb;
                --card-bg: #ffffff;
                --text: #1a1a2e;
                --muted: #8a8fa8;
                --border: #eaecf3;
                --shadow: 0 2px 16px rgba(0,0,0,0.07);
            }

            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            body {
                font-family: 'Poppins',sans-serif;
                background: var(--bg);
                color: var(--text);
            }

            .sidebar {
                position: fixed;
                top: 0;
                left: 0;
                width: var(--sidebar-w);
                height: 100vh;
                background: #1a1a2e;
                display: flex;
                flex-direction: column;
                z-index: 100;
                overflow-y: auto;
            }

            .sidebar-brand {
                padding: 18px 16px;
                border-bottom: 1px solid rgba(255,255,255,0.08);
                display: flex;
                align-items: center;
                gap: 10px;
            }

            .brand-name {
                font-size: 0.88rem;
                font-weight: 700;
                color: #fff;
                line-height: 1.2;
            }

            .brand-sub {
                font-size: 0.7rem;
                color: rgba(255,255,255,0.5);
            }

            .sidebar-nav {
                flex: 1;
                padding: 14px 10px;
            }

            .nav-label {
                font-size: 0.65rem;
                font-weight: 600;
                letter-spacing: 1px;
                text-transform: uppercase;
                color: rgba(255,255,255,0.3);
                padding: 10px 12px 5px;
            }

            .nav-item a {
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 10px 12px;
                border-radius: 9px;
                color: rgba(255,255,255,0.65);
                text-decoration: none;
                font-size: 0.88rem;
                font-weight: 500;
                transition: all 0.2s;
                margin-bottom: 2px;
            }

                .nav-item a:hover,
                .nav-item a.active {
                    background: rgba(232,69,69,0.18);
                    color: #fff;
                }

                .nav-item a.active {
                    color: var(--primary);
                }

            .nav-icon {
                font-size: 1rem;
                width: 20px;
                text-align: center;
            }

            .badge-count {
                margin-left: auto;
                background: var(--primary);
                color: #fff;
                border-radius: 20px;
                padding: 1px 7px;
                font-size: 0.68rem;
                font-weight: 700;
            }

            .sidebar-footer {
                padding: 14px 10px;
                border-top: 1px solid rgba(255,255,255,0.08);
            }

                .sidebar-footer a {
                    display: flex;
                    align-items: center;
                    gap: 10px;
                    padding: 9px 12px;
                    border-radius: 9px;
                    color: rgba(255,255,255,0.5);
                    text-decoration: none;
                    font-size: 0.85rem;
                    transition: all 0.2s;
                }

                    .sidebar-footer a:hover {
                        background: rgba(232,69,69,0.15);
                        color: var(--primary);
                    }

            .topbar {
                position: fixed;
                top: 0;
                left: var(--sidebar-w);
                right: 0;
                height: var(--topbar-h);
                background: #fff;
                border-bottom: 1px solid var(--border);
                display: flex;
                align-items: center;
                padding: 0 24px;
                gap: 12px;
                z-index: 99;
                box-shadow: var(--shadow);
            }

            .topbar-title {
                font-size: 1rem;
                font-weight: 700;
                color: var(--text);
                flex: 1;
            }

            .owner-pill {
                display: flex;
                align-items: center;
                gap: 8px;
                background: #f4f6fb;
                border-radius: 30px;
                padding: 5px 14px 5px 5px;
                border: 1.5px solid var(--border);
            }

            .owner-avatar {
                width: 30px;
                height: 30px;
                border-radius: 50%;
                background: var(--primary);
                color: #fff;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 0.78rem;
                font-weight: 700;
            }

            .owner-name {
                font-size: 0.83rem;
                font-weight: 600;
                color: var(--text);
            }

            .main-content {
                margin-left: var(--sidebar-w);
                margin-top: var(--topbar-h);
                padding: 24px;
                min-height: calc( 100vh - var(--topbar-h));
            }

            .page-heading {
                font-size: 1.35rem;
                font-weight: 700;
                color: var(--text);
                margin-bottom: 4px;
            }

            .page-sub {
                color: var(--muted);
                font-size: 0.88rem;
                margin-bottom: 20px;
            }

            .owner-card {
                background: #fff;
                border-radius: 16px;
                box-shadow: var(--shadow);
                padding: 22px;
                margin-bottom: 18px;
            }

                .owner-card h5 {
                    font-size: 0.95rem;
                    font-weight: 700;
                    color: var(--text);
                    margin-bottom: 14px;
                    padding-bottom: 10px;
                    border-bottom: 2px solid var(--border);
                }

            .stat-row {
                display: grid;
                grid-template-columns: repeat(auto-fit,minmax(150px,1fr));
                gap: 14px;
                margin-bottom: 20px;
            }

            .stat-box {
                background: var(--bg);
                border-radius: 12px;
                padding: 16px;
                text-align: center;
                border-left: 3px solid var(--primary);
            }

            .stat-val {
                font-size: 1.5rem;
                font-weight: 700;
                color: var(--text);
            }

            .stat-lbl {
                font-size: 0.73rem;
                color: var(--muted);
                margin-top: 3px;
            }

            .form-label {
                font-size: 0.85rem;
                font-weight: 600;
                color: #444;
                display: block;
                margin-bottom: 5px;
            }

            .form-control,
            .form-select {
                border-radius: 9px;
                border: 1.5px solid var(--border);
                padding: 9px 13px;
                font-size: 0.88rem;
                font-family: 'Poppins',sans-serif;
                width: 100%;
                transition: border-color 0.2s;
            }

                .form-control:focus,
                .form-select:focus {
                    outline: none;
                    border-color: var(--primary);
                    box-shadow: 0 0 0 3px rgba(232,69,69,0.1);
                }

            .btn-primary-o {
                background: var(--primary);
                color: #fff;
                border: none;
                border-radius: 9px;
                padding: 9px 20px;
                font-size: 0.88rem;
                font-weight: 600;
                cursor: pointer;
                font-family: 'Poppins',sans-serif;
                transition: background 0.2s;
            }

                .btn-primary-o:hover {
                    background: var(--primary-dk);
                }

            .btn-secondary-o {
                background: #f4f6fb;
                color: var(--text);
                border: 1.5px solid var(--border);
                border-radius: 9px;
                padding: 9px 18px;
                font-size: 0.88rem;
                font-weight: 600;
                cursor: pointer;
                font-family: 'Poppins',sans-serif;
            }

            .btn-danger-o {
                background: #fdecea;
                color: #c62828;
                border: 1.5px solid #f5c6c6;
                border-radius: 8px;
                padding: 5px 12px;
                font-size: 0.78rem;
                font-weight: 600;
                cursor: pointer;
                font-family: 'Poppins',sans-serif;
            }

            .btn-success-o {
                background: #e8f9ee;
                color: #1d7044;
                border: 1.5px solid #c3e6cb;
                border-radius: 8px;
                padding: 5px 12px;
                font-size: 0.78rem;
                font-weight: 600;
                cursor: pointer;
                font-family: 'Poppins',sans-serif;
            }

            .status-badge {
                display: inline-block;
                padding: 3px 10px;
                border-radius: 20px;
                font-size: 0.75rem;
                font-weight: 700;
            }

            .s-confirmed {
                background: #e8f9ee;
                color: #1d7044;
            }

            .s-delivered {
                background: #e3f2fd;
                color: #1565c0;
            }

            .s-cancelled {
                background: #fdecea;
                color: #c62828;
            }

            .s-pending {
                background: #fff8e1;
                color: #e65100;
            }

            table {
                width: 100%;
                border-collapse: collapse;
            }

                table th {
                    text-align: left;
                    font-size: 0.75rem;
                    font-weight: 700;
                    color: var(--muted);
                    text-transform: uppercase;
                    letter-spacing: 0.5px;
                    padding: 10px 14px;
                    border-bottom: 2px solid var(--border);
                    background: #f9fafc;
                }

                table td {
                    padding: 12px 14px;
                    font-size: 0.85rem;
                    color: var(--text);
                    border-bottom: 1px solid var(--border);
                    vertical-align: middle;
                }

                table tr:last-child td {
                    border-bottom: none;
                }

                table tr:hover td {
                    background: #fafbff;
                }

            .img-upload-wrap {
                border: 2px dashed var(--border);
                border-radius: 10px;
                padding: 14px;
                text-align: center;
                cursor: pointer;
                transition: all 0.2s;
                background: #fafbff;
                position: relative;
                min-height: 70px;
            }

                .img-upload-wrap:hover {
                    border-color: var(--primary);
                    background: #fff5f5;
                }

                .img-upload-wrap input[type="file"] {
                    position: absolute;
                    inset: 0;
                    opacity: 0;
                    cursor: pointer;
                    width: 100%;
                    height: 100%;
                }

            .img-upload-label {
                font-size: 0.78rem;
                color: var(--muted);
                pointer-events: none;
            }

            .food-thumb {
                width: 52px;
                height: 40px;
                object-fit: cover;
                border-radius: 7px;
                border: 1px solid var(--border);
            }

            .food-thumb-placeholder {
                width: 52px;
                height: 40px;
                border-radius: 7px;
                background: linear-gradient( 135deg,#f4f6fb,#e8ecf8);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1.3rem;
                border: 1px solid var(--border);
            }
    </style>
</head>
<body>

    <aside class="sidebar">
        <div class="sidebar-brand">
            <span style="font-size:1.4rem;">🍽️</span>
            <div>
                <div class="brand-name">
                    @(ViewBag.OwnerRestaurantName
                        ?? "Restaurant")
                </div>
                <div class="brand-sub">
                    Owner Portal
                </div>
            </div>
        </div>

        <nav class="sidebar-nav">
            <div class="nav-label">Main</div>

            <div class="nav-item">
                <a asp-controller="RestaurantOwner"
                   asp-action="Dashboard"
                   class="@(ViewContext.RouteData
                                      .Values["action"]?.ToString()
                                      == "Dashboard"
                                      ? "active" : "")">
                    <span class="nav-icon">📊</span>
                    Dashboard
                </a>
            </div>

            <div class="nav-item">
                <a asp-controller="RestaurantOwner"
                   asp-action="Menu"
                   class="@(ViewContext.RouteData
                                      .Values["action"]?.ToString()
                                      == "Menu"
                                      ? "active" : "")">
                    <span class="nav-icon">🧾</span>
                    Menu Items
                </a>
            </div>

            <div class="nav-item">
                <a asp-controller="RestaurantOwner"
                   asp-action="Orders"
                   class="@(ViewContext.RouteData
                                      .Values["action"]?.ToString()
                                      == "Orders"
                                      ? "active" : "")">
                    <span class="nav-icon">📦</span>
                    Orders
                    @if (ViewBag.PendingOrdersCount
                         != null &&
                         (int)ViewBag
                             .PendingOrdersCount > 0)
                    {
                        <span class="badge-count">
                            @ViewBag.PendingOrdersCount
                        </span>
                    }
                </a>
            </div>

            <div class="nav-item">
                <a asp-controller="RestaurantOwner"
                   asp-action="Reviews"
                   class="@(ViewContext.RouteData
                                      .Values["action"]?.ToString()
                                      == "Reviews"
                                      ? "active" : "")">
                    <span class="nav-icon">⭐</span>
                    Reviews
                </a>
            </div>

            <div class="nav-item">
                <a asp-controller="RestaurantOwner"
                   asp-action="Profile"
                   class="@(ViewContext.RouteData
                                      .Values["action"]?.ToString()
                                      == "Profile"
                                      ? "active" : "")">
                    <span class="nav-icon">🏪</span>
                    Restaurant Profile
                </a>
            </div>

        </nav>

        <div class="sidebar-footer">
            <a asp-controller="RestaurantOwner"
               asp-action="Logout">
                <span>🚪</span> Logout
            </a>
        </div>
    </aside>

    <header class="topbar">
        <div class="topbar-title">
            @ViewData["Title"]
        </div>
        <div class="owner-pill">
            <div class="owner-avatar">
                @(ViewBag.OwnerName?
                    .ToString()?
                    .Substring(0, 1)
                    .ToUpper() ?? "O")
            </div>
            <span class="owner-name">
                @(ViewBag.OwnerName ?? "Owner")
            </span>
        </div>
    </header>

    <main class="main-content">
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js">
    </script>

    @RenderSection("Scripts", required: false)

</body>
</html>