@model HungryHub.Models.CartViewModel
@{
    ViewData["Title"] = "Cart & Checkout";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewBag.UserFullName = Model.UserFullName;
}

<style>
    .checkout-grid {
        display:grid;
        grid-template-columns:1fr 380px;
        gap:22px;
    }
    @@media(max-width:900px) {
        .checkout-grid {
            grid-template-columns:1fr;
        }
    }

    .section-card {
        background:#fff;
        border-radius:18px;
        padding:22px;
        box-shadow:var(--shadow);
        margin-bottom:18px;
    }
    .section-card h5 {
        font-size:0.98rem;
        font-weight:700;
        margin-bottom:16px;
        padding-bottom:11px;
        border-bottom:2px solid var(--border);
        color:var(--text);
    }

    .cart-row {
        display:flex;
        align-items:center;
        gap:13px;
        padding:11px 0;
        border-bottom:1px solid var(--border);
    }
    .cart-row:last-child { border-bottom:none; }
    .ci-icon {
        font-size:1.9rem;
        width:46px;
        text-align:center;
        flex-shrink:0;
    }
    .ci-img {
        width:46px;
        height:46px;
        object-fit:cover;
        border-radius:8px;
        flex-shrink:0;
    }
    .ci-info { flex:1; }
    .ci-name {
        font-weight:600;
        font-size:0.9rem;
    }
    .ci-price {
        font-size:0.78rem;
        color:var(--muted);
        margin-top:2px;
    }
    .ci-subtotal {
        font-weight:700;
        color:var(--primary);
        font-size:0.92rem;
    }

    .form-label {
        font-weight:500;
        font-size:0.87rem;
        color:#444;
    }
    .form-control {
        border-radius:10px;
        border:1.5px solid var(--border);
        padding:10px 13px;
        font-size:0.9rem;
        width:100%;
        transition:border-color 0.2s;
        font-family:'Poppins',sans-serif;
    }
    .form-control:focus {
        outline:none;
        border-color:var(--primary);
        box-shadow:0 0 0 3px
            rgba(232,69,69,0.1);
    }

    /* Memo / receipt */
    .memo-box {
        background:#fff;
        border-radius:18px;
        box-shadow:var(--shadow);
        overflow:hidden;
        position:sticky;
        top:calc(var(--topbar-h) + 16px);
    }
    .memo-header {
        background:linear-gradient(
            135deg, #1a1a2e, #e84545);
        color:#fff;
        padding:18px 22px;
        text-align:center;
    }
    .memo-header h4 {
        font-weight:700;
        font-size:1.05rem;
        margin:0;
    }
    .memo-header p {
        font-size:0.78rem;
        opacity:0.8;
        margin:3px 0 0;
    }
    .memo-body { padding:18px 22px; }
    .memo-restaurant {
        text-align:center;
        font-weight:700;
        font-size:0.97rem;
        color:var(--text);
        margin-bottom:14px;
        padding-bottom:11px;
        border-bottom:2px dashed var(--border);
    }
    .memo-line {
        display:flex;
        justify-content:space-between;
        font-size:0.83rem;
        margin-bottom:7px;
        color:var(--text);
    }
    .memo-line .item-n { flex:1; }
    .memo-line .item-q {
        color:var(--muted);
        margin:0 10px;
    }
    .memo-line .item-p { font-weight:600; }
    .memo-divider {
        border:none;
        border-top:2px dashed var(--border);
        margin:11px 0;
    }
    .memo-total-line {
        display:flex;
        justify-content:space-between;
        font-size:0.85rem;
        color:var(--muted);
        margin-bottom:5px;
    }
    .memo-grand {
        display:flex;
        justify-content:space-between;
        font-size:1rem;
        font-weight:700;
        color:var(--text);
        padding-top:9px;
        border-top:2px solid var(--text);
        margin-top:4px;
    }
    .memo-footer {
        padding:14px 22px 18px;
    }
    .btn-place {
        width:100%;
        background:var(--primary);
        color:#fff;
        border:none;
        border-radius:12px;
        padding:13px;
        font-size:0.95rem;
        font-weight:700;
        cursor:pointer;
        transition:background 0.2s;
        margin-bottom:9px;
        font-family:'Poppins',sans-serif;
    }
    .btn-place:hover { background:var(--primary-dk); }
    .btn-pdf {
        width:100%;
        background:#fff;
        color:var(--text);
        border:1.5px solid var(--border);
        border-radius:12px;
        padding:10px;
        font-size:0.85rem;
        font-weight:600;
        cursor:pointer;
        transition:all 0.2s;
        font-family:'Poppins',sans-serif;
    }
    .btn-pdf:hover {
        border-color:var(--primary);
        color:var(--primary);
    }

    .empty-cart-wrap {
        text-align:center;
        padding:80px 20px;
    }
    .empty-cart-wrap .big { font-size:5rem; }
    .empty-cart-wrap h4 {
        font-weight:700;
        margin-top:12px;
    }
    .btn-browse {
        background:var(--primary);
        color:#fff;
        border:none;
        border-radius:12px;
        padding:12px 28px;
        font-weight:700;
        margin-top:16px;
        text-decoration:none;
        display:inline-block;
        transition:background 0.2s;
    }
    .btn-browse:hover {
        background:var(--primary-dk);
        color:#fff;
    }

    .btn-apply {
        background: var(--primary);
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: 9px 18px;
        font-weight: 600;
        font-size: 0.88rem;
        cursor: pointer;
        font-family: 'Poppins',sans-serif;
        transition: background 0.2s;
        white-space: nowrap;
    }

        .btn-apply:hover {
            background: var(--primary-dk);
        }

    .btn-remove {
        background: #fdecea;
        color: #c62828;
        border: 1.5px solid #f5c6c6;
        border-radius: 10px;
        padding: 9px 14px;
        font-weight: 600;
        font-size: 0.88rem;
        cursor: pointer;
        font-family: 'Poppins',sans-serif;
    }

    .coupon-success {
        background: #e8f9ee;
        border: 1px solid #c3e6cb;
        border-radius: 10px;
        padding: 10px 14px;
        color: #1d7044;
        font-weight: 600;
    }

    .coupon-error {
        background: #fdecea;
        border: 1px solid #f5c6c6;
        border-radius: 10px;
        padding: 10px 14px;
        color: #c62828;
        font-weight: 600;
    }

    .discount-row {
        display: flex;
        justify-content: space-between;
        font-size: 0.83rem;
        color: #1d7044;
        font-weight: 600;
        padding: 5px 0;
    }
</style>

@if (!Model.CartItems.Any())
{
    <div class="empty-cart-wrap">
        <div class="big">🛒</div>
        <h4>Your cart is empty</h4>
        <p style="color:var(--muted);">
            Add items from a restaurant
            to get started.
        </p>
        <a href="/Dashboard" class="btn-browse">
            Browse Restaurants
        </a>
    </div>
}
else
{
    <div class="d-flex align-items-center
                gap-3 mb-4">
        <div>
            <div style="font-size:1.4rem;
                        font-weight:700;
                        color:var(--text);">
                Checkout
            </div>
            <div style="color:var(--muted);
                        font-size:0.9rem;
                        margin-top:2px;">
                Order from
                @Model.RestaurantName
            </div>
        </div>
    </div>

    <form asp-controller="Order"
          asp-action="PlaceOrder"
          method="post"
          id="checkoutForm">
        @Html.AntiForgeryToken()

        <div class="checkout-grid">

            <!-- Left column -->
            <div>

                <!-- Cart items -->
                <div class="section-card">
                    <h5>
                        🛒 Order Items
                        (@Model.CartItems.Count)
                    </h5>
                    @foreach (var item in
                        Model.CartItems)
                    {
                        <div class="cart-row">
                            <div class="ci-icon">
                                @item.Icon
                            </div>
                            <div class="ci-info">
                                <div class="ci-name">
                                    @item.ItemName
                                </div>
                                <div class="ci-price">
                                    &#2547;@item.UnitPrice
                                        .ToString("0")
                                    x @item.Quantity
                                </div>
                            </div>
                            <div class="ci-subtotal">
                                &#2547;@item.SubTotal
                                    .ToString("0")
                            </div>
                        </div>
                    }
                </div>

                <!-- Delivery details -->
                <div class="section-card">
                    <h5>📍 Delivery Details</h5>
                    <div class="mb-3">
                        <label class="form-label">
                            Delivery Address *
                        </label>
                        <input type="text"
                               name="deliveryAddress"
                               class="form-control"
                               placeholder="Your full delivery address"
                               value="Chattogram, Bangladesh"
                               required/>
                    </div>
                    <div class="mb-1">
                        <label class="form-label">
                            Order Note (optional)
                        </label>
                        <textarea name="orderNote"
                                  class="form-control"
                                  rows="2"
                                  placeholder="Special instructions...">
                        </textarea>
                    </div>
                </div>

            </div>

            <!-- Coupon section -->
            <div class="section-card">
                <h5>🏷️ Have a Coupon?</h5>
                <div style="display:flex; gap:10px;">
                    <input type="text"
                           id="couponInput"
                           class="form-control"
                           placeholder="Enter coupon code"
                           style="text-transform:uppercase;
                    letter-spacing:1px;
                    max-width:260px;" />
                    <button type="button"
                            class="btn-apply"
                            onclick="applyCoupon()">
                        Apply
                    </button>
                    <button type="button"
                            class="btn-remove"
                            id="removeCouponBtn"
                            style="display:none;"
                            onclick="removeCoupon()">
                        Remove
                    </button>
                </div>

                <!-- Coupon result message -->
                <div id="couponMsg"
                     style="margin-top:10px;
                    font-size:0.85rem;
                    display:none;">
                </div>

                <!-- Hidden coupon fields sent with form -->
                <input type="hidden"
                       name="couponCode"
                       id="appliedCouponCode"
                       value="" />
                <input type="hidden"
                       name="discountAmount"
                       id="appliedDiscount"
                       value="0" />
            </div>

            <!-- Right column: Memo -->
            <div>
                <div class="memo-box"
                     id="memoBox">
                    <div class="memo-header">
                        <div style="font-size:1.7rem;
                                    margin-bottom:3px;">
                            🍔
                        </div>
                        <h4>HungryHub</h4>
                        <p>Order Memo</p>
                    </div>
                    <div class="memo-body">
                        <div class="memo-restaurant">
                            @Model.RestaurantName
                        </div>

                        <div style="font-size:0.73rem;
                                    color:var(--muted);
                                    margin-bottom:11px;">
                            📅 @DateTime.Now.ToString(
                                "dd MMM yyyy, hh:mm tt")
                            <br/>
                            👤 @Model.UserFullName
                            &nbsp;|&nbsp;
                            ✉️ @Model.UserEmail
                        </div>

                        @foreach (var item in
                            Model.CartItems)
                        {
                            <div class="memo-line">
                                <span class="item-n">
                                    @item.Icon
                                    @item.ItemName
                                </span>
                                <span class="item-q">
                                    x@item.Quantity
                                </span>
                                <span class="item-p">
                                    &#2547;@item.SubTotal
                                        .ToString("0")
                                </span>
                            </div>
                        }

                        <hr class="memo-divider"/>

                        <div class="memo-total-line">
                            <span>Subtotal</span>
                            <span>
                                &#2547;@Model.TotalAmount
                                    .ToString("0")
                            </span>
                        </div>
                        <div class="memo-total-line">
                            <span>Delivery fee</span>
                            <span>
                                &#2547;@Model.DeliveryFee
                                    .ToString("0")
                            </span>
                        </div>
                        <div class="memo-total-line">
                            <span>Tax (5%)</span>
                            <span>
                                &#2547;@((Model.TotalAmount
                                    * 0.05m)
                                    .ToString("0"))
                            </span>
                        </div>
                        <div class="memo-grand">
                            <span>GRAND TOTAL</span>
                            <span>
                                &#2547;@((Model.GrandTotal
                                    + Model.TotalAmount
                                    * 0.05m)
                                    .ToString("0"))
                            </span>
                        </div>
                    </div>
                    <div class="memo-footer">
                        <button type="submit"
                                class="btn-place">
                            🚀 Place Order
                        </button>
                        <button type="submit" class="btn-place">
                                  💳 Proceed to Payment
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </form>
}

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<script>
        var baseGrandTotal = @Model.GrandTotal;
        var appliedDiscount = 0;

        function applyCoupon()
        {
        var code = document.getElementById(
        'couponInput').value.trim();
        if (!code) {
        showCouponMsg(
        'Please enter a coupon code.',
        false);
        return;
        }

        var btn = document.querySelector('.btn-apply');
        btn.textContent = 'Checking...';
        btn.disabled = true;

        var token = document.querySelector(
        'input[name="__RequestVerificationToken"]')
        ?.value ?? '';

        fetch('/Coupon/ValidateCoupon', {
        method: 'POST',
        headers: {
        'Content-Type':
        'application/x-www-form-urlencoded'
        },
        body: 'code=' +
        encodeURIComponent(code) +
        '&orderAmount=' + baseGrandTotal +
        '&__RequestVerificationToken=' +
        encodeURIComponent(token)
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
        btn.textContent = 'Apply';
        btn.disabled = false;

        if (data.success) {
        appliedDiscount = data.discount;

        document.getElementById(
        'appliedCouponCode').value =
        data.code;
        document.getElementById(
        'appliedDiscount').value =
        data.discount;

        var newTotal = Math.max(
        0, baseGrandTotal - data.discount);

        document.getElementById(
        'grandTotalDisplay').innerHTML =
        '&#2547;' +
        Math.round(newTotal)
        .toLocaleString();

        var dRow = document.getElementById(
        'discountRowMemo');
        var dVal = document.getElementById(
        'discountValMemo');
        if (dRow && dVal) {
        dRow.style.display = 'flex';
        dVal.textContent =
        '-৳' +
        Math.round(data.discount)
        .toLocaleString();
        }

        document.getElementById(
        'removeCouponBtn')
        .style.display = 'inline-block';
        document.getElementById(
        'couponInput').disabled = true;

        showCouponMsg(
        '✅ ' + data.message, true);
        } else {
        showCouponMsg(
        '❌ ' + data.message, false);
        }
        })
        .catch(function() {
        btn.textContent = 'Apply';
        btn.disabled = false;
        showCouponMsg(
        '❌ Error checking coupon.', false);
        });
        }

        function removeCoupon() {
        appliedDiscount = 0;
        document.getElementById(
        'appliedCouponCode').value = '';
        document.getElementById(
        'appliedDiscount').value = '0';
        document.getElementById(
        'couponInput').value = '';
        document.getElementById(
        'couponInput').disabled = false;
        document.getElementById(
        'removeCouponBtn').style.display = 'none';
        document.getElementById(
        'grandTotalDisplay').innerHTML =
        '&#2547;' +
        Math.round(baseGrandTotal)
        .toLocaleString();

        var dRow = document.getElementById(
        'discountRowMemo');
        if (dRow) dRow.style.display = 'none';

        showCouponMsg('Coupon removed.', false);
        setTimeout(function() {
        var msg = document.getElementById(
        'couponMsg');
        if (msg) msg.style.display = 'none';
        }, 2000);
        }

        function showCouponMsg(msg, isSuccess) {
        var el = document.getElementById(
        'couponMsg');
        el.textContent = msg;
        el.className = isSuccess
        ? 'coupon-success'
        : 'coupon-error';
        el.style.display = 'block';
        }
    function downloadPDF() {
        var memo = document.getElementById('memoBox');
        var opt = {
            margin:      0.4,
            filename:    'HungryHub-Memo.pdf',
            image:       { type: 'jpeg', quality: 0.98 },
            html2canvas: { scale: 2 },
            jsPDF: {
                unit: 'in',
                format: 'a5',
                orientation: 'portrait'
            }
        };
        html2pdf().set(opt).from(memo).save();
    }
</script>
}