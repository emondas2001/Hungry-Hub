@{
    ViewData["Title"] = "Split Orders";
    Layout =
        "~/Views/Shared/_AdminLayout.cshtml";

    var splits =
        ViewBag.SplitList
        as List<HungryHub.Models.SplitOrder>
        ?? new List<HungryHub.Models.SplitOrder>();

    var emails =
        ViewBag.CreatorEmails
        as Dictionary<int, string>
        ?? new Dictionary<int, string>();
}

<div class="page-heading">Split Orders</div>
<div class="page-sub">
    View and manage all customer split orders
</div>

@if (ViewBag.SuccessMessage != null)
{
    <div class="alert alert-success
        alert-dismissible fade show"
         style="border-radius:12px;border:none;
        margin-bottom:16px;">
        @ViewBag.SuccessMessage
        <button type="button" class="btn-close"
                data-bs-dismiss="alert"></button>
    </div>
}

<div class="admin-table-card">
    <div class="admin-table-header">
        <div class="admin-table-title">
            All Split Orders (@splits.Count)
        </div>
    </div>

    @if (!splits.Any())
    {
        <div style="text-align:center;
            padding:40px;
            color:var(--muted);">
            No split orders yet.
        </div>
    }
    else
    {
        @foreach (var split in splits)
        {
            string creatorEmail = emails
                .ContainsKey(split.CreatorUserId)
                ? emails[split.CreatorUserId]
                 : "Unknown";

            int paidCount =
                split.Participants
                    .Count(p => p.IsPaid);

            <div style="background:#f8f9ff;
                border-radius:14px;
                padding:18px;
                margin:16px;
                border:1.5px solid
                var(--border);">
                <div style="display:flex;
                    align-items:center;
                    justify-content:space-between;
                    margin-bottom:12px;
                    flex-wrap:wrap;
                    gap:10px;">
                    <div>
                        <div style="font-weight:700;
                            font-size:0.95rem;">
                            Split #@split.SplitOrderId
                            — Order #@split.OrderId
                        </div>
                        <div style="font-size:0.8rem;
                            color:var(--muted);
                            margin-top:3px;">
                            By: @creatorEmail
                            &nbsp;|&nbsp;
                            Type: @split.SplitType
                            &nbsp;|&nbsp;
                            Total: ৳@split.TotalAmount
                            .ToString("N0")
                            &nbsp;|&nbsp;
                            @paidCount /
                            @split.Participants.Count
                            paid
                            &nbsp;|&nbsp;
                            @split.CreatedAt
                            .ToString("dd MMM yyyy")
                        </div>
                    </div>
                    <form asp-controller="Admin"
                          asp-action="DeleteSplitAdmin"
                          method="post"
                          style="margin:0;"
                          onsubmit="return confirm(
                        'Delete this split?');">
                        @Html.AntiForgeryToken()
                        <input type="hidden"
                               name="splitOrderId"
                               value="@split.SplitOrderId" />
                        <button type="submit"
                                class="btn-danger-sm">
                            Delete
                        </button>
                    </form>
                </div>

                <table style="width:100%;">
                    <thead>
                        <tr style="font-size:0.75rem;
                            color:var(--muted);
                            text-transform:uppercase;">
                            <th style="padding:6px 10px;">
                                Name
                            </th>
                            <th style="padding:6px 10px;">
                                Email
                            </th>
                            <th style="padding:6px 10px;">
                                Amount Owed
                            </th>
                            <th style="padding:6px 10px;">
                                Status
                            </th>
                            <th style="padding:6px 10px;">
                                Paid At
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in
                            split.Participants)
                        {
                            <tr style="font-size:0.85rem;
                                border-top:1px solid
                                var(--border);">
                                <td style="padding:8px 10px;
                                    font-weight:600;">
                                    @p.Name
                                </td>
                                <td style="padding:8px 10px;
                                    color:var(--muted);">
                                    @(p.Email ?? "—")
                                </td>
                                <td style="padding:8px 10px;
                                    font-weight:700;
                                    color:var(--primary);">
                                    ৳@p.AmountOwed
                                    .ToString("N0")
                                </td>
                                <td style="padding:8px 10px;">
                                    @if (p.IsPaid)
                                    {
                                        <span style="background:#e8f9ee;
                                            color:#1d7044;
                                            border-radius:20px;
                                            padding:2px 10px;
                                            font-size:0.72rem;
                                            font-weight:700;">
                                            Paid
                                        </span>
                                    }
                                    else
                                    {
                                        <span style="background:#fdecea;
                                            color:#c62828;
                                            border-radius:20px;
                                            padding:2px 10px;
                                            font-size:0.72rem;
                                            font-weight:700;">
                                            Unpaid
                                        </span>
                                    }
                                </td>
                                <td style="padding:8px 10px;
                                    color:var(--muted);
                                    font-size:0.78rem;">
                                    @(p.PaidAt.HasValue
                                        ? p.PaidAt.Value
                                            .ToString("dd MMM yyyy")
                                        : "—")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
</div>