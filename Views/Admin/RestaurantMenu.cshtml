@{
    ViewData["Title"] = "Restaurant Menu";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    var rest = ViewBag.Restaurant
        as HungryHub.Models.RestaurantDb;
    var items = ViewBag.ItemList
        as List<HungryHub.Models.MenuItem>
        ?? new List<HungryHub.Models.MenuItem>();
}

<style>
    .img-upload-wrap {
        border: 2px dashed var(--border);
        border-radius: 12px;
        padding: 12px;
        text-align: center;
        cursor: pointer;
        transition: all 0.2s;
        background: #fafbff;
        position: relative;
        min-height: 80px;
    }

        .img-upload-wrap:hover {
            border-color: var(--primary);
            background: #fff5f5;
        }

        .img-upload-wrap input[type="file"] {
            position: absolute;
            inset: 0;
            opacity: 0;
            cursor: pointer;
            width: 100%;
            height: 100%;
        }

    .img-upload-label {
        font-size: 0.78rem;
        color: var(--muted);
        pointer-events: none;
    }

    .food-img-preview {
        width: 100%;
        height: 70px;
        object-fit: cover;
        border-radius: 8px;
        display: none;
        margin-bottom: 4px;
    }

    .food-thumb {
        width: 64px;
        height: 48px;
        object-fit: cover;
        border-radius: 8px;
        border: 1px solid var(--border);
    }

    .food-thumb-placeholder {
        width: 64px;
        height: 48px;
        border-radius: 8px;
        background: linear-gradient( 135deg, #f4f6fb, #e8ecf8);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        border: 1px solid var(--border);
    }
</style>

<div class="page-heading">
    Menu — @rest?.Name
</div>
<div class="page-sub">
    Add, toggle, or delete menu items
    for this restaurant
</div>

@if (ViewBag.SuccessMessage != null)
{
    <div class="alert alert-success
        alert-dismissible fade show"
         style="border-radius:12px; border:none;
        margin-bottom:16px;">
        @ViewBag.SuccessMessage
        <button type="button" class="btn-close"
                data-bs-dismiss="alert"></button>
    </div>
}

<!-- Navigation buttons -->
<div style="margin-bottom:12px; display:flex;
    gap:10px;">
    <a href="/Admin/Restaurants"
           class="btn-admin"
           style="background:#f4f6fb;
        color:var(--text);">
        Back
    </a>
    <a href="/Admin/RestaurantHours/@rest?.RestaurantId"
           class="btn-admin"
           style="background:#339af0;">
        Edit Hours
    </a>
</div>

<!-- Add Menu Item Form -->
<div class="admin-table-card mb-4">
    <div class="admin-table-header">
        <div class="admin-table-title">
            Add Menu Item
        </div>
    </div>
    <div style="padding:20px;">

        <form asp-controller="Admin"
              asp-action="AddMenuItem"
              method="post"
              enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden"
                   name="restaurantId"
                   value="@rest?.RestaurantId" />

            <div class="row g-3">

                <!-- Item Name -->
                <div class="col-md-3">
                    <label class="form-label"
                           style="font-size:0.83rem;
                        font-weight:600;">
                        Item Name *
                    </label>
                    <input type="text"
                           name="name"
                           id="itemNameInput"
                           class="form-control"
                           placeholder="e.g. Mutton Kacchi"
                           required />
                </div>

                <!-- Category -->
                <div class="col-md-2">
                    <label class="form-label"
                           style="font-size:0.83rem;
                        font-weight:600;">
                        Category *
                    </label>
                    <input type="text"
                           name="category"
                           id="categoryInput"
                           class="form-control"
                           placeholder="e.g. Main"
                           required />
                </div>

                <!-- Price -->
                <div class="col-md-2">
                    <label class="form-label"
                           style="font-size:0.83rem;
                        font-weight:600;">
                        Price (BDT) *
                    </label>
                    <input type="number"
                           name="price"
                           id="priceInput"
                           class="form-control"
                           placeholder="e.g. 320"
                           min="0"
                           step="0.01"
                           required />
                </div>

                <!-- Food Photo Upload -->
                <div class="col-md-3">
                    <label class="form-label"
                           style="font-size:0.83rem;
                        font-weight:600;">
                        Food Photo
                    </label>
                    <div class="img-upload-wrap">
                        <input type="file"
                               name="foodImage"
                               accept="image/*"
                               onchange="previewFood(
                        this,
                        'foodPreview',
                        'foodLabel')" />
                        <img id="foodPreview"
                             class="food-img-preview"
                             src="" alt="Preview" />
                        <div id="foodLabel"
                             class="img-upload-label">
                            <div style="font-size:1.3rem;">
                                🍽️
                            </div>
                            <div style="margin-top:2px;">
                                Upload food photo
                            </div>
                            <div style="font-size:0.7rem;
                                color:#bbb;
                                margin-top:2px;">
                                Auto-resized 600×400
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Hidden icon field
                     (kept for DB compatibility) -->
                <input type="hidden"
                       name="icon"
                       value="🍽️" />

                <!-- Description -->
                <div class="col-md-2">
                    <label class="form-label"
                           style="font-size:0.83rem;
                        font-weight:600;">
                        Description
                    </label>
                    <input type="text"
                           name="description"
                           id="descInput"
                           class="form-control"
                           placeholder="Brief description" />
                </div>

                <!-- Submit -->
                <div class="col-12">
                    <button type="submit"
                            class="btn-admin">
                        Add Item
                    </button>
                    <button type="button"
                            class="btn-admin"
                            style="background:#f4f6fb;
                        color:var(--text);
                        margin-left:8px;"
                            onclick="clearForm()">
                        Clear
                    </button>
                </div>

            </div>
        </form>
    </div>
</div>

<!-- Menu Items Table -->
<div class="admin-table-card">
    <div class="admin-table-header">
        <div class="admin-table-title">
            Menu Items (@items.Count)
        </div>
    </div>
    <table>
        <thead>
            <tr>
                <th>Photo</th>
                <th>Name</th>
                <th>Category</th>
                <th>Price</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in items)
            {
                <tr>
                    <td>
                        @if (!string.IsNullOrEmpty(
                            item.ImagePath))
                        {
                            <img src="@item.ImagePath"
                                 class="food-thumb"
                                 alt="@item.Name" />
                        }
                        else
                        {
                            <div class="food-thumb-placeholder">
                                @item.Icon
                            </div>
                        }
                    </td>
                    <td>
                        <div style="font-weight:600;">
                            @item.Name
                        </div>
                        <div style="font-size:0.75rem;
                            color:var(--muted);">
                            @item.Description
                        </div>
                    </td>
                    <td>
                        <span style="background:#f0f4ff;
                            border-radius:6px;
                            padding:3px 10px;
                            font-size:0.78rem;
                            font-weight:600;">
                            @item.Category
                        </span>
                    </td>
                    <td style="font-weight:700;
                        color:var(--primary);">
                        &#2547;@item.Price.ToString("0")
                    </td>
                    <td>
                        @if (item.IsAvailable)
                        {
                            <span class="status-badge
                                s-confirmed">
                                Available
                            </span>
                        }
                        else
                        {
                            <span class="status-badge
                                s-cancelled">
                                Unavailable
                            </span>
                        }
                    </td>
                    <td>
                        <div style="display:flex;
                            gap:6px;">

                            <form asp-controller="Admin"
                                  asp-action="ToggleMenuItem"
                                  method="post"
                                  style="margin:0;">
                                @Html.AntiForgeryToken()
                                <input type="hidden"
                                       name="menuItemId"
                                       value="@item.MenuItemId" />
                                <button type="submit"
                                        class="@(item.IsAvailable
                                                                                                                        ? "btn-danger-sm"
                                                                                                                        : "btn-success-sm")">
                                    @(item.IsAvailable
                                        ? "Disable"
                                        : "Enable")
                                </button>
                            </form>

                            <form asp-controller="Admin"
                                  asp-action="DeleteMenuItem"
                                  method="post"
                                  style="margin:0;"
                                  onsubmit="return confirm(
                                'Delete @item.Name?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden"
                                       name="menuItemId"
                                       value="@item.MenuItemId" />
                                <button type="submit"
                                        class="btn-danger-sm">
                                    Delete
                                </button>
                            </form>

                        </div>
                    </td>
                </tr>
            }

            @if (!items.Any())
            {
                <tr>
                    <td colspan="6"
                        style="text-align:center;
                        padding:40px;
                        color:var(--muted);">
                        No menu items yet.
                        Use the form above to add one.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        function previewFood(input, previewId, labelId) {
            var preview =
                document.getElementById(previewId);
            var label =
                document.getElementById(labelId);
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function(e) {
                    preview.src = e.target.result;
                    preview.style.display = 'block';
                    if (label)
                        label.style.display = 'none';
                };
                reader.readAsDataURL(input.files[0]);
            }
        }

        function clearForm() {
            document.getElementById(
                'itemNameInput').value = '';
            document.getElementById(
                'categoryInput').value = '';
            document.getElementById(
                'priceInput').value    = '';
            document.getElementById(
                'descInput').value     = '';

            var preview =
                document.getElementById('foodPreview');
            var label =
                document.getElementById('foodLabel');
            preview.style.display = 'none';
            preview.src           = '';
            if (label)
                label.style.display = 'block';
        }
    </script>
}