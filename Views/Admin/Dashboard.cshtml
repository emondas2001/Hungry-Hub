    <div class="kpi-card"
         style="border-top-color:#339af0;">
        <div class="kpi-val"
             style="color:#339af0;">
            &#2547;@string.Format("{0:N0}",
                ViewBag.WeekRevenue)
        </div>
        <div class="kpi-lbl">This Week</div>
    </div>
    <div class="kpi-card"
         style="border-top-color:#f59f00;">
        <div class="kpi-val"
             style="color:#f59f00;">
            &#2547;@ViewBag.AvgOrderValue
        </div>
