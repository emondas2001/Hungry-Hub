        </div>
    </div>
</div>

<!-- ── REVENUE KPI ROW ── -->
<div class="kpi-row">
    <div class="kpi-card">
        <div class="kpi-val">
            &#2547;@string.Format("{0:N0}",
                ViewBag.TotalRevenue)
