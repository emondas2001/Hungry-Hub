<!-- BUSINESS INTELLIGENCE PANEL                  -->
<!-- ════════════════════════════════════════════ -->

<div class="section-title-lg">
    Business Intelligence Panel
</div>

<div class="bi-grid">

    <!-- Orders per day bar chart -->
    <div class="chart-card">
        <div class="chart-card-header">
            <div class="chart-card-title">
                Orders — Last 7 Days
            </div>
            <span style="font-size:0.78rem;
                          color:var(--muted);">
                Daily volume
            </span>
        </div>
        <div class="chart-card-body">
            @{
                var opd = ViewBag.OrdersPerDay
                    as IEnumerable<dynamic>
                    ?? new List<dynamic>();
                int maxO = 1;
                foreach (var d in opd)
                    if ((int)d.Count > maxO)
                        maxO = (int)d.Count;
            }
            <div class="bar-chart-wrap">
                @foreach (var day in opd)
                {
                    int pct = maxO > 0
                        ? Math.Max(4,
                            (int)((double)(int)day.Count
                                / maxO * 130))
                        : 4;
                    <div class="bar-col">
                        <div class="bar-val">
                            @day.Count
                        </div>
                        <div class="bar-fill"
                             style="height:@(pct)px;
                                    background:var(--primary);">
                        </div>
                        <div class="bar-label">
                            @day.Date
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Revenue per day bar chart -->
    <div class="chart-card">
        <div class="chart-card-header">
            <div class="chart-card-title">
                Revenue — Last 7 Days
            </div>
            <span style="font-size:0.78rem;
                          color:var(--muted);">
                BDT per day
            </span>
        </div>
        <div class="chart-card-body">
            @{
                var rpd = ViewBag.RevenuePerDay
                    as IEnumerable<dynamic>
                    ?? new List<dynamic>();
                double maxR = 1;
                foreach (var d in rpd)
                    if ((double)d.Revenue > maxR)
                        maxR = (double)d.Revenue;
            }
            <div class="bar-chart-wrap">
                @foreach (var day in rpd)
                {
                    int pct = maxR > 0
                        ? Math.Max(4,
                            (int)((double)day.Revenue
                                / maxR * 130))
                        : 4;
                    <div class="bar-col">
                        <div class="bar-val"
                             style="font-size:0.58rem;">
                            &#2547;@string.Format(
                                "{0:N0}", day.Revenue)
                        </div>
                        <div class="bar-fill"
                             style="height:@(pct)px;
                                    background:#339af0;">
                        </div>
                        <div class="bar-label">
                            @day.Date
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Orders by status donut -->
    <div class="chart-card">
        <div class="chart-card-header">
            <div class="chart-card-title">
                Orders by Status
            </div>
        </div>
        <div class="chart-card-body">
            @{
                var obs = ViewBag.OrdersByStatus
                    as IEnumerable<dynamic>
                    ?? new List<dynamic>();

                int confirmed = 0, delivered = 0,
                    cancelled = 0;
                foreach (var s in obs)
                {
                    if (s.Status == "Confirmed")
                        confirmed = (int)s.Count;
                    else if (s.Status == "Delivered")
                        delivered = (int)s.Count;
                    else if (s.Status == "Cancelled")
                        cancelled = (int)s.Count;
                }

                int total2 = confirmed + delivered +
                             cancelled;
                if (total2 == 0) total2 = 1;

                double cPct = (double)confirmed /
                              total2 * 100;
                double dPct = (double)delivered /
                              total2 * 100;
                double xPct = (double)cancelled /
                              total2 * 100;

                // SVG donut segments
                double r = 45, cx = 55, cy = 55;
                double circ = 2 * Math.PI * r;

                double cDash = cPct / 100 * circ;
                double dDash = dPct / 100 * circ;
                double xDash = xPct / 100 * circ;

                double dOffset = circ - cDash;
                double xOffset = dOffset - dDash;
            }
            <div class="donut-wrap">
                <svg width="110" height="110"
                     class="donut-svg"
                     viewBox="0 0 110 110">
                    <circle cx="@cx" cy="@cy"
                            r="@r" fill="none"
                            stroke="#f4f6fb"
                            stroke-width="18"/>
                    @if (confirmed > 0)
                    {
                        <circle cx="@cx" cy="@cy"
                                r="@r" fill="none"
                                stroke="#1d7044"
                                stroke-width="18"
                                stroke-dasharray="@cDash @(circ - cDash)"
                                stroke-dashoffset="@(circ * 0.25)"
                                transform="rotate(-90 @cx @cy)"/>
                    }
                    @if (delivered > 0)
                    {
                        <circle cx="@cx" cy="@cy"
                                r="@r" fill="none"
                                stroke="#339af0"
                                stroke-width="18"
                                stroke-dasharray="@dDash @(circ - dDash)"
                                stroke-dashoffset="@(circ * 0.25 - cDash)"
                                transform="rotate(-90 @cx @cy)"/>
                    }
                    @if (cancelled > 0)
                    {
                        <circle cx="@cx" cy="@cy"
                                r="@r" fill="none"
                                stroke="#c62828"
                                stroke-width="18"
                                stroke-dasharray="@xDash @(circ - xDash)"
                                stroke-dashoffset="@(circ * 0.25 - cDash - dDash)"
                                transform="rotate(-90 @cx @cy)"/>
                    }
                    <text x="@cx" y="@(cy + 5)"
                          text-anchor="middle"
                          font-size="11"
                          font-weight="700"
                          fill="#1a1a2e">
                        @total2
                    </text>
                    <text x="@cx" y="@(cy + 16)"
                          text-anchor="middle"
                          font-size="7"
                          fill="#8a8fa8">
                        total
                    </text>
                </svg>
                <div class="donut-legend">
                    <div class="legend-item">
                        <div class="legend-dot"
                             style="background:#1d7044;">
                        </div>
                        <span>
                            Confirmed —
                            @confirmed
                            (@Math.Round(cPct, 0)%)
                        </span>
                    </div>
                    <div class="legend-item">
                        <div class="legend-dot"
                             style="background:#339af0;">
                        </div>
                        <span>
                            Delivered —
                            @delivered
                            (@Math.Round(dPct, 0)%)
                        </span>
                    </div>
                    <div class="legend-item">
                        <div class="legend-dot"
                             style="background:#c62828;">
                        </div>
                        <span>
                            Cancelled —
                            @cancelled
                            (@Math.Round(xPct, 0)%)
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Top 5 menu items -->
    <div class="chart-card">
        <div class="chart-card-header">
            <div class="chart-card-title">
                Top 5 Menu Items
            </div>
            <span style="font-size:0.78rem;
                          color:var(--muted);">
                By quantity ordered
            </span>
        </div>
        <div class="chart-card-body">
            @{
                var tmi = ViewBag.TopMenuItems
                    as IEnumerable<dynamic>
                    ?? new List<dynamic>();
                int maxQty = 1;
                foreach (var m in tmi)
                    if ((int)m.Quantity > maxQty)
                        maxQty = (int)m.Quantity;
            }
            @foreach (var m in tmi)
            {
                int barW = maxQty > 0
                    ? (int)((double)(int)m.Quantity
                        / maxQty * 100)
                    : 0;
                <div class="top-item-row">
                    <div style="flex:1;">
                        <div style="font-weight:600;">
                            @m.Name
                        </div>
                        <div class="top-item-bar"
                             style="width:@(barW)%">
                        </div>
                    </div>
                    <div style="text-align:right;
                                margin-left:12px;">
                        <div style="font-weight:700;
                                    color:var(--primary);">
                            x@m.Quantity
                        </div>
                        <div style="font-size:0.72rem;
                                    color:var(--muted);">
                            &#2547;@string.Format(
                                "{0:N0}", m.Revenue)
                        </div>
                    </div>
                </div>
            }
            @if (!tmi.Any())
            {
                <p style="color:var(--muted);
                           font-size:0.85rem;
                           text-align:center;
                           padding:20px 0;">
                    No orders yet
                </p>
            }
        </div>
    </div>

    <!-- Top restaurants -->
    <div class="chart-card">
        <div class="chart-card-header">
            <div class="chart-card-title">
                Top Restaurants by Revenue
            </div>
        </div>
        <div class="chart-card-body">
            @{
                var rr = ViewBag.RestaurantRevenue
                    as IEnumerable<dynamic>
                    ?? new List<dynamic>();
                decimal maxRev2 = 1;
                foreach (var rv in rr)
                    if ((decimal)rv.Revenue > maxRev2)
                        maxRev2 = (decimal)rv.Revenue;
            }
            @foreach (var rv in rr)
            {
                int bw2 = maxRev2 > 0
                    ? (int)((double)(decimal)rv.Revenue
                        / (double)maxRev2 * 100)
                    : 0;
                <div class="rev-row">
                    <div style="flex:1;">
                        <div style="font-weight:600;
                                    font-size:0.88rem;">
                            @rv.Name
                        </div>
                        <div style="height:5px;
                                    border-radius:3px;
                                    background:#339af0;
                                    width:@(bw2)%;
                                    margin-top:4px;">
                        </div>
                    </div>
                    <div style="text-align:right;
                                margin-left:12px;">
                        <div style="font-weight:700;
                                    color:#339af0;
                                    font-size:0.88rem;">
                            &#2547;@string.Format(
                                "{0:N0}", rv.Revenue)
                        </div>
                        <div style="font-size:0.72rem;
                                    color:var(--muted);">
                            @rv.Orders orders
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- User growth -->
    <div class="chart-card">
        <div class="chart-card-header">
            <div class="chart-card-title">
                User Growth — Last 4 Weeks
            </div>
        </div>
        <div class="chart-card-body">
            @{
                var ug = ViewBag.UserGrowth
                    as IEnumerable<dynamic>
                    ?? new List<dynamic>();
                int maxUG = 1;
                foreach (var w in ug)
                    if ((int)w.Count > maxUG)
                        maxUG = (int)w.Count;
            }
            <div class="bar-chart-wrap"
                 style="height:110px;">
                @foreach (var w in ug)
                {
                    int ph = maxUG > 0
                        ? Math.Max(4,
                            (int)((double)(int)w.Count
                                / maxUG * 100))
                        : 4;
                    <div class="bar-col">
                        <div class="bar-val">@w.Count</div>
                        <div class="bar-fill"
                             style="height:@(ph)px;
                                    background:#cc5de8;">
                        </div>
                        <div class="bar-label">
                            @w.Week
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

</div>

<!-- Peak hours -->
<div class="chart-card mb-4">
    <div class="chart-card-header">
        <div class="chart-card-title">
            Peak Order Hours
        </div>
        <span style="font-size:0.78rem;
                      color:var(--muted);">
            Top 5 busiest hours of the day
        </span>
    </div>
    <div class="chart-card-body">
        @{
            var ph2 = ViewBag.PeakHours
                as IEnumerable<dynamic>
                ?? new List<dynamic>();
        }
        @if (!ph2.Any())
        {
            <p style="color:var(--muted);
                       font-size:0.85rem;">
                No order data yet.
            </p>
        }
        else
        {
            @foreach (var h in ph2)
            {
                string ampm =
                    (int)h.Hour < 12 ? "AM" : "PM";
                int h12 = (int)h.Hour % 12;
                if (h12 == 0) h12 = 12;
                <span class="peak-pill">
                    🕐 @(h12):00 @ampm
                    <strong>@h.Count orders</strong>
                </span>
            }
        }
    </div>
</div>

<!-- Recent orders table -->
<div class="admin-table-card mb-4">
    <div class="admin-table-header">
        <div class="admin-table-title">
            Recent Orders
        </div>
        <a href="/Admin/Orders" class="btn-admin">
            View All
        </a>
    </div>
    <table>
        <thead>
            <tr>
                <th>#ID</th>
                <th>User</th>
                <th>Restaurant</th>
                <th>Amount</th>
                <th>Status</th>
                <th>Date</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var o in
                ViewBag.RecentOrders
                as IEnumerable<dynamic>
                ?? new List<dynamic>())
            {
                string sc =
                    o.Status == "Confirmed"
                        ? "s-confirmed" :
                    o.Status == "Delivered"
                        ? "s-delivered" :
                    o.Status == "Cancelled"
                        ? "s-cancelled" :
                    "s-pending";

                <tr>
                    <td style="font-weight:700;">
                        #@o.OrderId
                    </td>
                    <td style="color:var(--muted);
                               font-size:0.8rem;">
                        @o.UserEmail
                    </td>
                    <td>@o.RestaurantName</td>
                    <td style="font-weight:700;
                               color:var(--primary);">
                        &#2547;@string.Format(
                            "{0:N0}", o.GrandTotal)
                    </td>
                    <td>
                        <span class="status-badge @sc">
                            @o.Status
                        </span>
                    </td>
                    <td style="color:var(--muted);
                               font-size:0.78rem;">
                        @((DateTime)o.OrderDate)
                            .ToString("dd MMM, HH:mm")
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- New users -->
<div class="admin-table-card">
    <div class="admin-table-header">
        <div class="admin-table-title">
            Recent Users
        </div>
        <a href="/Admin/Users" class="btn-admin">
            View All
        </a>
    </div>
    <div style="padding:10px 20px 16px;">
        @foreach (var u in
            ViewBag.RecentUsers
            as IEnumerable<HungryHub.Models.User>
            ?? new List<HungryHub.Models.User>())
        {
            string ini =
                (u.FirstName.Length > 0
                    ? u.FirstName[0].ToString() : "") +
                (u.LastName.Length > 0
                    ? u.LastName[0].ToString() : "");

            <div style="display:flex; align-items:center;
                        gap:12px; padding:10px 0;
                        border-bottom:1px solid
                        var(--border);">
                <div style="width:36px; height:36px;
                            border-radius:50%;
                            background:linear-gradient(
                                135deg,#e84545,#1a1a2e);
                            color:#fff;
                            display:flex;
                            align-items:center;
                            justify-content:center;
                            font-size:0.85rem;
                            font-weight:700;">
                    @ini.ToUpper()
                </div>
                <div style="flex:1; min-width:0;">
                    <div style="font-weight:600;
                                font-size:0.88rem;">
                        @u.FirstName @u.LastName
                    </div>
                    <div style="font-size:0.78rem;
                                color:var(--muted);">
                        @u.Email
                    </div>
                </div>
                <div style="font-size:0.75rem;
                            color:var(--muted);">
                    @u.CreatedAt.ToString("dd MMM")
                </div>
            </div>
        }
    </div>
</div>