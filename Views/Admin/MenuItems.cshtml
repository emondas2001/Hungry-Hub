@{
    ViewData["Title"] = "Menu Management";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    var restNames =
        ViewBag.RestaurantNames
        as Dictionary<int, string>
        ?? new Dictionary<int, string>();
}

<div class="page-heading">Menu Management</div>
<div class="page-sub">Add, toggle availability or delete menu items</div>

@if (ViewBag.SuccessMessage != null)
{
    <div class="alert alert-success alert-dismissible fade show"
         style="border-radius:12px; border:none; margin-bottom:16px;">
        @ViewBag.SuccessMessage
        <button type="button" class="btn-close"
                data-bs-dismiss="alert"></button>
    </div>
}

<!-- Add Item Form -->
<div class="admin-table-card mb-4">
    <div class="admin-table-header">
        <div class="admin-table-title">Add New Menu Item</div>
    </div>
    <div style="padding:20px;">
        <form asp-controller="Admin"
              asp-action="AddMenuItem"
              method="post">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label"
                           style="font-size:0.83rem;
                        font-weight:600;">
                        Restaurant
                    </label>
                    <select name="restaurantId"
                            class="form-select" required>
                        <option value="">Select restaurant</option>
                        @foreach (var r in restNames)
                        {
                            <option value="@r.Key">@r.Value</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label"
                           style="font-size:0.83rem;
                        font-weight:600;">
                        Item Name
                    </label>
                    <input type="text" name="name"
                           class="form-control"
                           placeholder="e.g. Chicken Burger"
                           required />
                </div>
                <div class="col-md-3">
                    <label class="form-label"
                           style="font-size:0.83rem;
                        font-weight:600;">
                        Category
                    </label>
                    <input type="text" name="category"
                           class="form-control"
                           placeholder="e.g. Burgers"
                           required />
                </div>
                <div class="col-md-1">
                    <label class="form-label"
                           style="font-size:0.83rem;
                        font-weight:600;">
                        Icon
                    </label>
                    <input type="text" name="icon"
                           class="form-control"
                           placeholder="🍔"
                           maxlength="4" />
                </div>
                <div class="col-md-2">
                    <label class="form-label"
                           style="font-size:0.83rem;
                        font-weight:600;">
                        Price (BDT)
                    </label>
                    <input type="number" name="price"
                           class="form-control"
                           placeholder="250"
                           min="0" step="0.01" required />
                </div>
                <div class="col-12">
                    <label class="form-label"
                           style="font-size:0.83rem;
                        font-weight:600;">
                        Description
                    </label>
                    <input type="text" name="description"
                           class="form-control"
                           placeholder="Brief description of the item" />
                </div>
                <div class="col-12">
                    <button type="submit" class="btn-admin">
                        Add Menu Item
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Search -->
<div style="margin-bottom:16px;">
    <form method="get" asp-action="MenuItems"
          style="display:flex; gap:10px;">
        <input type="text" name="search"
               value="@ViewBag.Search"
               class="form-control"
               placeholder="Search items..."
               style="max-width:300px;" />
        <button type="submit" class="btn-admin">Search</button>
        @if (ViewBag.Search != null)
        {
            <a href="/Admin/MenuItems"
                   class="btn-admin"
                   style="background:#f4f6fb; color:var(--text);">
                Clear
            </a>
        }
    </form>
</div>

<div class="admin-table-card">
    <div class="admin-table-header">
        <div class="admin-table-title">All Menu Items</div>
    </div>
    <table>
        <thead>
            <tr>
                <th>Icon</th>
                <th>Name</th>
                <th>Restaurant</th>
                <th>Category</th>
                <th>Price</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in
                ViewBag.ItemList
                as List<HungryHub.Models.MenuItem>
                ?? new List<HungryHub.Models.MenuItem>())
            {
                restNames.TryGetValue(
                    item.RestaurantId,
                    out string? rName);

                <tr>
                    <td style="font-size:1.5rem;">
                        @item.Icon
                    </td>
                    <td>
                        <div style="font-weight:600;">
                            @item.Name
                        </div>
                        <div style="font-size:0.75rem;
                            color:var(--muted);">
                            @item.Description
                        </div>
                    </td>
                    <td>@(rName ?? "Unknown")</td>
                    <td>
                        <span style="background:#f0f4ff;
                            border-radius:6px;
                            padding:3px 10px;
                            font-size:0.78rem;
                            font-weight:600;">
                            @item.Category
                        </span>
                    </td>
                    <td style="font-weight:700;
                        color:var(--primary);">
                        &#2547;@item.Price.ToString("0")
                    </td>
                    <td>
                        @if (item.IsAvailable)
                        {
                            <span class="status-badge s-confirmed">
                                Available
                            </span>
                        }
                        else
                        {
                            <span class="status-badge s-cancelled">
                                Unavailable
                            </span>
                        }
                    </td>
                    <td>
                        <div style="display:flex; gap:6px;">
                            <form asp-controller="Admin"
                                  asp-action="ToggleMenuItem"
                                  method="post" style="margin:0;">
                                @Html.AntiForgeryToken()
                                <input type="hidden"
                                       name="menuItemId"
                                       value="@item.MenuItemId" />
                                <button type="submit"
                                        class="@(item.IsAvailable
                                                                                                                        ? "btn-danger-sm"
                                                                                                                        : "btn-success-sm")">
                                    @(item.IsAvailable
                                        ? "Disable"
                                        : "Enable")
                                </button>
                            </form>

                            <form asp-controller="Admin"
                                  asp-action="DeleteMenuItem"
                                  method="post" style="margin:0;"
                                  onsubmit="return confirm(
                                'Delete @item.Name?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden"
                                       name="menuItemId"
                                       value="@item.MenuItemId" />
                                <button type="submit"
                                        class="btn-danger-sm">
                                    Delete
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>