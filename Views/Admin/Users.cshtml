@{
    ViewData["Title"] = "User Management";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-heading">User Management</div>
<div class="page-sub">View, search and manage all registered users</div>

@if (ViewBag.SuccessMessage != null)
{
    <div class="alert alert-success alert-dismissible fade show"
         style="border-radius:12px; border:none; margin-bottom:16px;">
        @ViewBag.SuccessMessage
        <button type="button" class="btn-close"
                data-bs-dismiss="alert"></button>
    </div>
}

<!-- Search bar -->
<div class="admin-table-card mb-4">
    <div style="padding:16px 20px;">
        <form method="get" asp-action="Users"
              style="display:flex; gap:10px;">
            <input type="text" name="search"
                   value="@ViewBag.Search"
                   class="form-control"
                   placeholder="Search by name, email or phone..."
                   style="max-width:400px;" />
            <button type="submit" class="btn-admin">
                Search
            </button>
            @if (ViewBag.Search != null)
            {
                <a href="/Admin/Users"
                       class="btn-admin"
                       style="background:#f4f6fb; color:var(--text);">
                    Clear
                </a>
            }
        </form>
    </div>
</div>

<div class="admin-table-card">
    <div class="admin-table-header">
        <div class="admin-table-title">
            All Users
            (@((ViewBag.UserList as List<HungryHub.Models.User>)
                            ?.Count ?? 0) total)
        </div>
    </div>
    <table>
        <thead>
            <tr>
                <th>#</th>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Gender</th>
                <th>DOB</th>
                <th>Orders</th>
                <th>Joined</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @{
                var userList =
                    ViewBag.UserList
                    as List<HungryHub.Models.User>
                    ?? new List<HungryHub.Models.User>();

                var orderCounts =
                    ViewBag.UserOrderCounts
                    as Dictionary<int, int>
                    ?? new Dictionary<int, int>();
            }
            @foreach (var u in userList)
            {
                string initials =
                    (u.FirstName.Length > 0
                        ? u.FirstName[0].ToString() : "") +
                    (u.LastName.Length > 0
                        ? u.LastName[0].ToString() : "");

                orderCounts.TryGetValue(
                    u.UserId, out int oCount);

                <tr>
                    <td style="font-weight:700; color:var(--muted);">
                        @u.UserId
                    </td>
                    <td>
                        <div style="display:flex;
                            align-items:center; gap:10px;">
                            <div style="width:32px; height:32px;
                                border-radius:50%;
                                background:linear-gradient(
                                135deg,#e84545,#1a1a2e);
                                color:#fff;
                                display:flex;
                                align-items:center;
                                justify-content:center;
                                font-size:0.78rem;
                                font-weight:700;
                                flex-shrink:0;">
                                @initials.ToUpper()
                            </div>
                            <span style="font-weight:600;">
                                @u.FirstName @u.LastName
                            </span>
                        </div>
                    </td>
                    <td style="color:var(--muted); font-size:0.82rem;">
                        @u.Email
                    </td>
                    <td>@u.PhoneNumber</td>
                    <td>@u.Gender</td>
                    <td style="color:var(--muted); font-size:0.8rem;">
                        @u.DateOfBirth.ToString("dd MMM yyyy")
                    </td>
                    <td>
                        <span style="background:#f0f4ff;
                            border-radius:8px;
                            padding:3px 10px;
                            font-weight:700;
                            font-size:0.83rem;
                            color:#1a1a2e;">
                            @oCount
                        </span>
                    </td>
                    <td style="color:var(--muted); font-size:0.8rem;">
                        @u.CreatedAt.ToString("dd MMM yyyy")
                    </td>
                    <td>
                        <form asp-controller="Admin"
                              asp-action="DeleteUser"
                              method="post" style="margin:0;"
                              onsubmit="return confirm(
                            'Delete user @u.FirstName? ' +
                            'All their orders will also be deleted.');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="userId"
                                   value="@u.UserId" />
                            <button type="submit"
                                    class="btn-danger-sm">
                                Delete
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>