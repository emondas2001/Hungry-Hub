@{
    ViewData["Title"] = "Pre-Orders";
    Layout =
        "~/Views/Shared/_AdminLayout.cshtml";

    var preOrders =
        ViewBag.PreOrderList
        as List<HungryHub.Models.PreOrder>
        ?? new List<HungryHub.Models.PreOrder>();

    var userEmails =
        ViewBag.UserEmails
        as Dictionary<int, string>
        ?? new Dictionary<int, string>();

    string filterStatus =
        ViewBag.FilterStatus ?? "";
}

<div class="page-heading">
    Pre-Order Management
</div>
<div class="page-sub">
    Manage event catering pre-orders
    from customers
</div>

@if (ViewBag.SuccessMessage != null)
{
    <div class="alert alert-success
        alert-dismissible fade show"
         style="border-radius:12px;border:none;
        margin-bottom:16px;">
        @ViewBag.SuccessMessage
        <button type="button" class="btn-close"
                data-bs-dismiss="alert">
        </button>
    </div>
}

<!-- Filter tabs -->
<div style="display:flex; gap:8px;
    margin-bottom:16px;
    flex-wrap:wrap;">
    @foreach (var s in new[]
    {
        "", "Pending", "Confirmed", "Cancelled"
    })
    {
        string label = s == "" ? "All" : s;
        bool active = filterStatus == s;
        <a href="/Admin/PreOrders?status=@s"
           style="padding:7px 16px;
            border-radius:20px;
            font-size:0.83rem;
            font-weight:600;
            text-decoration:none;
            transition:all 0.2s;
            border:1.5px solid
            @(active
               ? "var(--primary)"
               : "var(--border)");
            background:
            @(active
               ? "var(--primary)"
               : "#fff");
            color:
            @(active
               ? "#fff"
               : "var(--text)");">
            @label
        </a>
    }
</div>

@if (!preOrders.Any())
{
    <div class="admin-table-card"
         style="padding:40px;
        text-align:center;
        color:var(--muted);">
        No pre-orders found.
    </div>
}
else
{
    @foreach (var po in preOrders)
    {
        string email = userEmails
    .ContainsKey(po.UserId)
    ? userEmails[po.UserId]
    : "Unknown";

        string sc = po.Status switch
        {
            "Confirmed" => "s-confirmed",
            "Cancelled" => "s-cancelled",
            _ => "s-pending"
        };

        <div class="admin-table-card mb-3">
            <div style="padding:18px 22px;">

                <!-- Header row -->
                <div style="display:flex;
                    align-items:flex-start;
                    justify-content:space-between;
                    flex-wrap:wrap;
                    gap:12px;
                    margin-bottom:14px;">
                    <div>
                        <div style="font-weight:700;
                            font-size:1rem;">
                            🎉 @po.EventName
                        </div>
                        <div style="font-size:0.82rem;
                            color:var(--muted);
                            margin-top:4px;">
                            Customer: @email
                            &nbsp;|&nbsp;
                            Restaurant:
                            @po.RestaurantName
                        </div>
                        <div style="font-size:0.82rem;
                            color:var(--muted);
                            margin-top:2px;">
                            📅 @po.EventDate.ToString(
                                                            "dd MMM yyyy, hh:mm tt")
                            &nbsp;|&nbsp;
                            👥 @po.GuestCount guests
                            &nbsp;|&nbsp;
                            📍 @po.EventAddress
                        </div>
                        @if (!string.IsNullOrEmpty(
                            po.SpecialRequests))
                        {
                            <div style="font-size:0.8rem;
                                color:var(--muted);
                                margin-top:2px;">
                                💬 @po.SpecialRequests
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(
                            po.AdminNote))
                        {
                            <div style="background:#fff8e1;
                                border-radius:8px;
                                padding:6px 12px;
                                margin-top:8px;
                                font-size:0.8rem;
                                color:#5d4037;">
                                📝 Admin note:
                                @po.AdminNote
                            </div>
                        }
                    </div>
                    <div style="text-align:right;">
                        <span class="status-badge @sc">
                            @po.Status
                        </span>
                        <div style="font-size:0.88rem;
                            font-weight:700;
                            color:var(--primary);
                            margin-top:6px;">
                            Total: ৳@po.TotalAmount
                            .ToString("N0")
                        </div>
                        <div style="font-size:0.75rem;
                            color:var(--muted);">
                            Advance: ৳@po.AdvanceAmount
                            .ToString("N0")
                        </div>
                        <div style="font-size:0.75rem;
                            color:var(--muted);">
                            Submitted:
                            @po.CreatedAt.ToString(
                                "dd MMM yyyy")
                        </div>
                    </div>
                </div>

                <!-- Menu items -->
                @if (po.Items.Any())
                {
                    <div style="background:#f4f6fb;
                        border-radius:10px;
                        padding:12px 16px;
                        margin-bottom:14px;">
                        <div style="font-size:0.75rem;
                            font-weight:700;
                            color:var(--muted);
                            margin-bottom:8px;
                            letter-spacing:0.5px;">
                            MENU ITEMS
                        </div>
                        @foreach (var item in po.Items)
                        {
                            <div style="display:flex;
                                justify-content:space-between;
                                font-size:0.83rem;
                                padding:4px 0;
                                border-bottom:1px solid
                                var(--border);">
                                <span>
                                    @item.ItemName
                                    &nbsp;×&nbsp;
                                    @item.Quantity
                                    <span style="color:var(--muted);
                                        font-size:0.75rem;">
                                        (@item.UnitPrice
                                        .ToString("N0") each)
                                    </span>
                                </span>
                                <span style="font-weight:600;">
                                    ৳@item.SubTotal
                                    .ToString("N0")
                                </span>
                            </div>
                        }
                    </div>
                }

                <!-- Admin actions: PENDING -->
                @if (po.Status == "Pending")
                {
                    <div style="display:flex;
                        gap:10px;
                        flex-wrap:wrap;
                        align-items:flex-end;">

                        <!-- Confirm form -->
                        <form asp-controller="Admin"
                              asp-action="UpdatePreOrderStatus"
                              method="post"
                              style="display:flex;
                            gap:8px;
                            flex:1;
                            min-width:280px;
                            align-items:flex-end;">
                            @Html.AntiForgeryToken()
                            <input type="hidden"
                                   name="preOrderId"
                                   value="@po.PreOrderId" />
                            <input type="hidden"
                                   name="newStatus"
                                   value="Confirmed" />
                            <div style="flex:1;">
                                <label style="font-size:0.78rem;
                                    font-weight:600;
                                    color:var(--muted);
                                    display:block;
                                    margin-bottom:4px;">
                                    Admin Note (optional)
                                </label>
                                <input type="text"
                                       name="adminNote"
                                       class="form-control"
                                       style="height:36px;
                                border-radius:8px;
                                border:1.5px solid
                                var(--border);
                                padding:6px 12px;
                                font-size:0.85rem;
                                font-family:'Poppins',
                                sans-serif;
                                width:100%;"
                                       placeholder="e.g. Confirmed, advance received" />
                            </div>
                            <button type="submit"
                                    class="btn-success-sm">
                                ✅ Confirm
                            </button>
                        </form>

                        <!-- Reject form -->
                        <form asp-controller="Admin"
                              asp-action="UpdatePreOrderStatus"
                              method="post"
                              style="margin:0;"
                              onsubmit="return confirm(
                            'Reject this pre-order?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden"
                                   name="preOrderId"
                                   value="@po.PreOrderId" />
                            <input type="hidden"
                                   name="newStatus"
                                   value="Cancelled" />
                            <input type="hidden"
                                   name="adminNote"
                                   value="Rejected by admin" />
                            <button type="submit"
                                    class="btn-danger-sm">
                                ❌ Reject
                            </button>
                        </form>

                        <!-- Delete form -->
                        <form asp-controller="Admin"
                              asp-action="DeletePreOrder"
                              method="post"
                              style="margin:0;"
                              onsubmit="return confirm(
                            'Permanently delete this pre-order?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden"
                                   name="preOrderId"
                                   value="@po.PreOrderId" />
                            <button type="submit"
                                    class="btn-danger-sm">
                                🗑 Delete
                            </button>
                        </form>

                    </div>
                }
                else
                {
                    <!-- Confirmed or Cancelled:
                         only show delete -->
                    <div style="display:flex;
                        gap:8px;">
                        <form asp-controller="Admin"
                              asp-action="DeletePreOrder"
                              method="post"
                              style="margin:0;"
                              onsubmit="return confirm(
                            'Delete this pre-order?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden"
                                   name="preOrderId"
                                   value="@po.PreOrderId" />
                            <button type="submit"
                                    class="btn-danger-sm">
                                🗑 Delete
                            </button>
                        </form>
                    </div>
                }

            </div>
        </div>
    }
}