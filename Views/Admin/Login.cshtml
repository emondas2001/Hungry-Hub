@model HungryHub.Models.AdminLoginViewModel
@{
    ViewData["Title"] = "Admin Login";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>
    <title>HungryHub Admin Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
          rel="stylesheet"/>
    <style>
        body {
            background:linear-gradient(135deg,#0f0f1f,#1a1a2e);
            font-family:'Segoe UI',sans-serif;
            min-height:100vh;
            display:flex; align-items:center;
            justify-content:center;
        }
        .login-card {
            background:#fff; border-radius:20px;
            box-shadow:0 20px 60px rgba(0,0,0,0.4);
            padding:40px; width:100%; max-width:420px;
        }
        .brand {
            font-size:1.8rem; font-weight:700;
            color:#e84545; text-align:center; margin-bottom:4px;
        }
        .brand span { color:#333; }
        .admin-tag {
            display:inline-block;
            background:#1a1a2e; color:#fff;
            border-radius:8px; padding:3px 14px;
            font-size:0.73rem; font-weight:700;
            letter-spacing:1.5px; margin-bottom:24px;
        }
        .form-label {
            font-weight:500; font-size:0.88rem; color:#444;
        }
        .form-control {
            border-radius:10px;
            border:1.5px solid #e0e0e0;
            padding:11px 14px; font-size:0.92rem;
            transition:all 0.2s;
        }
        .form-control:focus {
            border-color:#e84545;
            box-shadow:0 0 0 3px rgba(232,69,69,0.12);
            outline:none;
        }
        .input-group .form-control {
            border-right:none;
            border-radius:10px 0 0 10px;
        }
        .btn-eye {
            border:1.5px solid #e0e0e0; border-left:none;
            border-radius:0 10px 10px 0;
            background:#fff; padding:0 14px;
            color:#888; cursor:pointer;
            transition:color 0.2s;
        }
        .btn-eye:hover { color:#e84545; }
        .btn-login {
            background:#e84545; color:#fff;
            border:none; border-radius:12px;
            padding:13px; font-size:1rem;
            font-weight:700; width:100%;
            cursor:pointer; transition:background 0.2s;
            margin-top:8px;
        }
        .btn-login:hover { background:#c73535; }
        .security-note {
            background:#f8f9ff;
            border:1.5px solid #e0e4ff;
            border-radius:10px; padding:12px 16px;
            font-size:0.78rem; color:#555;
            margin-top:16px; text-align:center;
        }
    </style>
</head>
<body>
<div class="login-card">

    <div class="brand">🍔 Hungry<span>Hub</span></div>
    <div class="text-center">
        <span class="admin-tag">ADMIN PANEL</span>
    </div>

    @if (ViewBag.SuccessMessage != null)
    {
        <div class="alert alert-success"
             style="border-radius:10px; border:none; font-size:0.88rem;">
            @ViewBag.SuccessMessage
        </div>
    }

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger"
             style="border-radius:10px; border:none; font-size:0.88rem;">
            @ViewBag.Error
        </div>
    }

    <form asp-controller="Admin"
          asp-action="Login" method="post">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label asp-for="Email" class="form-label">
                Admin Email
            </label>
            <input asp-for="Email" class="form-control"
                   placeholder="admin@hungryhub.com"
                   autocomplete="email"/>
            <span asp-validation-for="Email"
                  class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Password" class="form-label">
                Password
            </label>
            <div class="input-group">
                <input asp-for="Password" type="password"
                       class="form-control"
                       placeholder="Enter admin password"
                       id="adminPw"
                       autocomplete="current-password"/>
                <button type="button" class="btn-eye"
                        onclick="togglePw()">👁</button>
            </div>
            <span asp-validation-for="Password"
                  class="text-danger small"></span>
        </div>

        <button type="submit" class="btn-login">
            Login to Admin Panel
        </button>
    </form>

    <div class="security-note">
        🔒 This panel is restricted to authorized administrators only.
        Unauthorized access attempts are logged.
    </div>

    <p style="text-align:center; color:#aaa;
               font-size:0.8rem; margin-top:16px;">
        <a href="/" style="color:#e84545; font-weight:600;">
            Back to HungryHub
        </a>
    </p>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
<script>
    function togglePw() {
        var pw  = document.getElementById('adminPw');
        var btn = pw.nextElementSibling;
        pw.type     = pw.type === 'password' ? 'text' : 'password';
        btn.textContent = pw.type === 'password' ? '👁' : '🙈';
    }
</script>
</body>
</html>