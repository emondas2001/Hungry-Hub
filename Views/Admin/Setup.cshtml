@model HungryHub.Models.Admin
@{
    ViewData["Title"] = "Admin Setup";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>
    <title>HungryHub Admin Setup</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
          rel="stylesheet"/>
    <style>
        body {
            background:linear-gradient(135deg,#0f0f1f,#1a1a2e);
            font-family:'Segoe UI',sans-serif;
            min-height:100vh;
            display:flex; align-items:center;
            justify-content:center;
            padding:40px 0;
        }
        .setup-card {
            background:#fff; border-radius:20px;
            box-shadow:0 20px 60px rgba(0,0,0,0.4);
            padding:40px; width:100%; max-width:580px;
        }
        .brand {
            font-size:1.8rem; font-weight:700;
            color:#e84545; text-align:center;
            margin-bottom:4px;
        }
        .brand span { color:#333; }
        .admin-badge {
            background:#e84545; color:#fff;
            border-radius:8px; padding:3px 12px;
            font-size:0.75rem; font-weight:700;
            letter-spacing:1px;
        }
        .section-label {
            font-size:0.75rem; font-weight:700;
            color:#e84545; text-transform:uppercase;
            letter-spacing:1px; margin-bottom:16px;
            padding-bottom:10px;
            border-bottom:2px solid #f0f0f0;
        }
        .form-label {
            font-weight:500; font-size:0.88rem;
            color:#444;
        }
        .form-control {
            border-radius:10px;
            border:1.5px solid #e0e0e0;
            padding:10px 14px;
            background:#f8f9ff;
            color:#333;
            font-size:0.9rem;
        }
        .password-box {
            background:linear-gradient(135deg,#1a1a2e,#e84545);
            border-radius:14px; padding:20px;
            text-align:center; margin:16px 0;
        }
        .password-display {
            font-family:'Courier New',monospace;
            font-size:1.4rem; font-weight:700;
            color:#fff; letter-spacing:3px;
            background:rgba(255,255,255,0.1);
            border-radius:10px; padding:12px 20px;
            margin:10px 0;
            word-break:break-all;
        }
        .warning-box {
            background:#fff8e1; border:1.5px solid #ffd54f;
            border-radius:12px; padding:14px 18px;
            font-size:0.85rem; color:#5d4037;
            margin-bottom:20px;
        }
        .btn-setup {
            background:#e84545; color:#fff;
            border:none; border-radius:12px;
            padding:14px; font-size:1rem;
            font-weight:700; width:100%;
            cursor:pointer; transition:background 0.2s;
        }
        .btn-setup:hover { background:#c73535; }
        .readonly-field {
            background:#f0f2f8; color:#666;
        }
        .gender-group { display:flex; gap:10px; }
        .gender-option { flex:1; position:relative; }
        .gender-option input[type="radio"] {
            position:absolute; opacity:0; width:0;
        }
        .gender-option label {
            display:flex; align-items:center;
            justify-content:center;
            border:1.5px solid #e0e0e0;
            border-radius:10px; padding:9px;
            cursor:default; font-size:0.88rem;
            background:#f0f2f8; color:#888;
            width:100%;
        }
        .gender-option input[type="radio"]:checked + label {
            border-color:#e84545;
            background:#fff5f5; color:#e84545;
            font-weight:600;
        }
    </style>
</head>
<body>
<div class="setup-card">

    <div class="brand">🍔 Hungry<span>Hub</span></div>
    <div class="text-center mb-4">
        <span class="admin-badge">ADMIN SETUP</span>
    </div>

    <div class="warning-box">
        <strong>One-time setup only.</strong> This page will be permanently
        disabled after the admin account is created. Save your
        credentials before proceeding.
    </div>

    <div class="section-label">Admin Account Information</div>

    <!-- Display-only form showing what will be created -->
    <div class="row mb-3">
        <div class="col-sm-6 mb-3 mb-sm-0">
            <label class="form-label">First Name</label>
            <input type="text" class="form-control readonly-field"
                   value="@Model.FirstName" readonly/>
        </div>
        <div class="col-sm-6">
            <label class="form-label">Last Name</label>
            <input type="text" class="form-control readonly-field"
                   value="@Model.LastName" readonly/>
        </div>
    </div>

    <div class="mb-3">
        <label class="form-label">Email Address</label>
        <input type="text" class="form-control readonly-field"
               value="@Model.Email" readonly/>
    </div>

    <div class="mb-3">
        <label class="form-label">Phone Number</label>
        <input type="text" class="form-control readonly-field"
               value="@Model.PhoneNumber" readonly/>
    </div>

    <div class="mb-3">
        <label class="form-label">Gender</label>
        <div class="gender-group">
            <div class="gender-option">
                <input type="radio" id="gM" name="g" value="Male"
                       @(Model.Gender=="Male" ? "checked" : "") disabled/>
                <label for="gM">Male</label>
            </div>
            <div class="gender-option">
                <input type="radio" id="gF" name="g" value="Female"
                       @(Model.Gender=="Female" ? "checked" : "") disabled/>
                <label for="gF">Female</label>
            </div>
            <div class="gender-option">
                <input type="radio" id="gO" name="g" value="Other"
                       @(Model.Gender=="Other" ? "checked" : "") disabled/>
                <label for="gO">Other</label>
            </div>
        </div>
    </div>

    <div class="mb-3">
        <label class="form-label">Date of Birth</label>
        <input type="date" class="form-control readonly-field"
               value="@Model.DateOfBirth.ToString("yyyy-MM-dd")"
               readonly/>
    </div>

    <!-- Password display box -->
    <div class="section-label">Generated Admin Password</div>
    <div class="password-box">
        <div style="color:rgba(255,255,255,0.7);
                    font-size:0.82rem; margin-bottom:6px;">
            Your secure admin password
        </div>
        <div class="password-display" id="pwDisplay">
            ••••••••••••••••
        </div>
        <button type="button"
                onclick="togglePw()"
                style="background:rgba(255,255,255,0.15);
                       border:1px solid rgba(255,255,255,0.3);
                       border-radius:8px; padding:6px 18px;
                       color:#fff; font-size:0.82rem;
                       cursor:pointer; font-weight:600;">
            Show Password
        </button>
        <div style="color:rgba(255,255,255,0.6);
                    font-size:0.75rem; margin-top:10px;">
            Save this password before proceeding. It will not be
            shown again.
        </div>
    </div>

    <!-- Confirm and create -->
    <form asp-controller="Admin"
          asp-action="SetupConfirm"
          method="post"
          onsubmit="return confirm(
              'Create admin account? This cannot be undone.');">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn-setup">
            Create Admin Account
        </button>
    </form>

    <p style="text-align:center; color:#aaa;
               font-size:0.8rem; margin-top:16px;">
        Already have an account?
        <a href="/Admin/Login"
           style="color:#e84545; font-weight:600;">
            Login here
        </a>
    </p>
</div>

<script>
    var shown = false;
    var realPw = '@ViewBag.PlainPassword';

    function togglePw() {
        var el  = document.getElementById('pwDisplay');
        var btn = el.nextElementSibling;
        shown = !shown;
        el.textContent  = shown ? realPw : '••••••••••••••••';
        btn.textContent = shown ? 'Hide Password' : 'Show Password';
    }
</script>
</body>
</html>