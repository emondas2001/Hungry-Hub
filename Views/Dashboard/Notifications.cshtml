@model List<HungryHub.Models.Notification>
@{
    ViewData["Title"] = "Notifications";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<style>
    .page-title    { font-size:1.4rem; font-weight:700; color:var(--text); }
    .page-subtitle { color:var(--muted); font-size:0.9rem; margin-top:2px; }

    .notif-list { margin-top: 20px; }

    .notif-card {
        background: #fff;
        border-radius: 14px;
        padding: 16px 20px;
        margin-bottom: 12px;
        box-shadow: var(--shadow);
        display: flex;
        align-items: flex-start;
        gap: 14px;
        transition: transform 0.2s;
        border-left: 4px solid var(--border);
    }
    .notif-card:hover { transform: translateX(4px); }
    .notif-card.unread { border-left-color: var(--primary); }

    .notif-icon-wrap {
        width: 44px; height: 44px;
        border-radius: 12px;
        background: #fff5f5;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        flex-shrink: 0;
    }

    .notif-body { flex: 1; }

    .notif-title {
        font-weight: 700;
        font-size: 0.95rem;
        color: var(--text);
        margin-bottom: 3px;
    }

    .notif-msg {
        font-size: 0.85rem;
        color: var(--muted);
        line-height: 1.5;
    }

    .notif-time {
        font-size: 0.75rem;
        color: var(--muted);
        margin-top: 6px;
    }

    .unread-dot {
        width: 10px; height: 10px;
        border-radius: 50%;
        background: var(--primary);
        flex-shrink: 0;
        margin-top: 6px;
    }

    .btn-clear {
        background: #fdecea;
        border: 1.5px solid #f5c6c6;
        border-radius: 10px;
        padding: 8px 18px;
        font-size: 0.85rem;
        font-weight: 600;
        color: #c62828;
        cursor: pointer;
        transition: all 0.2s;
    }
    .btn-clear:hover {
        background: #c62828;
        color: #fff;
        border-color: #c62828;
    }

    .empty-notif {
        text-align: center;
        padding: 80px 20px;
        background: #fff;
        border-radius: 18px;
        box-shadow: var(--shadow);
        margin-top: 20px;
    }
    .empty-notif .big { font-size: 4rem; }

    .time-ago {
        display: inline-block;
        background: #f4f6fb;
        border-radius: 20px;
        padding: 2px 10px;
        font-size: 0.73rem;
        color: var(--muted);
        margin-top: 4px;
    }
</style>

<div class="d-flex align-items-center justify-content-between mb-2">
    <div>
        <div class="page-title">Notifications</div>
        <div class="page-subtitle">
            @Model.Count total &nbsp;|&nbsp;
            All caught up!
        </div>
    </div>

    @if (Model.Any())
    {
        <form asp-controller="Dashboard"
              asp-action="ClearNotifications"
              method="post" style="margin:0;"
              onsubmit="return confirm('Clear all notifications?');">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn-clear">
                Clear All
            </button>
        </form>
    }
</div>

@if (!Model.Any())
{
    <div class="empty-notif">
        <div class="big">🔔</div>
        <h4 style="font-weight:700; margin-top:12px;">
            No notifications
        </h4>
        <p style="color:var(--muted);">
            Order food to get started — confirmations and updates appear here.
        </p>
    </div>
}
else
{
    <div class="notif-list">
        @foreach (var n in Model)
        {
            <div class="notif-card @(!n.IsRead ? "unread" : "")">
                <div class="notif-icon-wrap">@n.Icon</div>
                <div class="notif-body">
                    <div class="notif-title">@n.Title</div>
                    <div class="notif-msg">@n.Message</div>
                    <div class="notif-time">
                        <span class="time-ago">
                            @n.CreatedAt.ToString("dd MMM yyyy, hh:mm tt")
                        </span>
                        @if (!n.IsRead)
                        {
                            <span style="color:var(--primary);
                                         font-size:0.73rem;
                                         font-weight:600;
                                         margin-left:8px;">
                                NEW
                            </span>
                        }
                    </div>
                </div>
                @if (!n.IsRead)
                {
                    <div class="unread-dot"></div>
                }
            </div>
        }
    </div>
}