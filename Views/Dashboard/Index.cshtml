@model HungryHub.Models.DashboardViewModel
@using HungryHub.Models
@{
    ViewData["Title"] = "Dashboard";
    Layout =
        "~/Views/Shared/_DashboardLayout.cshtml";
    ViewBag.UserFullName = Model.UserFullName;
    ViewBag.SearchQuery = Model.SearchQuery;

    var favIds =
        ViewBag.FavouriteIds as List<int>
        ?? new List<int>();

    var weather =
        ViewBag.Weather as WeatherData;

    var coupons =
        ViewBag.ActiveCoupons
        as List<Coupon>
        ?? new List<Coupon>();
}

<style>
    .page-title {
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--text);
    }

    .page-subtitle {
        color: var(--muted);
        font-size: 0.9rem;
        margin-top: 2px;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(170px,1fr));
        gap: 16px;
        margin-bottom: 24px;
    }

    .stat-card {
        background: var(--card-bg);
        border-radius: 16px;
        padding: 18px 20px;
        box-shadow: var(--shadow);
        display: flex;
        align-items: center;
        gap: 14px;
        transition: transform 0.2s;
    }

        .stat-card:hover {
            transform: translateY(-3px);
        }

    .stat-icon {
        width: 46px;
        height: 46px;
        border-radius: 13px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        flex-shrink: 0;
    }

    .stat-label {
        font-size: 0.76rem;
        color: var(--muted);
        font-weight: 500;
    }

    .stat-value {
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--text);
        line-height: 1.2;
    }

    .stat-sub {
        font-size: 0.72rem;
        color: #51cf66;
        font-weight: 500;
        margin-top: 2px;
    }

    .weather-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        margin-bottom: 24px;
    }

    @@media(max-width:700px) {
        .weather-grid {
            grid-template-columns: 1fr;
        }
    }

    .hero-banner {
        background: linear-gradient( 135deg,#1a1a2e 0%,#e84545 100%);
        border-radius: 20px;
        padding: 28px 32px;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        overflow: hidden;
        position: relative;
    }

        .hero-banner::before {
            content: '';
            position: absolute;
            top: -40px;
            right: 120px;
            width: 200px;
            height: 200px;
            background: rgba(255,255,255,0.05);
            border-radius: 50%;
        }

    .hero-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #fff;
        line-height: 1.3;
    }

    .hero-sub {
        color: rgba(255,255,255,0.75);
        font-size: 0.88rem;
        margin-top: 6px;
    }

    .hero-btn {
        background: #fff;
        color: var(--primary);
        border: none;
        border-radius: 12px;
        padding: 11px 22px;
        font-weight: 700;
        font-size: 0.88rem;
        margin-top: 14px;
        text-decoration: none;
        display: inline-block;
        transition: transform 0.2s;
        font-family: 'Poppins',sans-serif;
    }

        .hero-btn:hover {
            transform: scale(1.04);
            color: var(--primary);
        }

    .hero-emoji {
        font-size: 4.5rem;
        filter: drop-shadow( 0 4px 12px rgba(0,0,0,0.25));
    }

    .section-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 14px;
    }

    .section-title-sm {
        font-size: 1.02rem;
        font-weight: 700;
        color: var(--text);
    }

    .see-all {
        font-size: 0.82rem;
        color: var(--primary);
        font-weight: 600;
        text-decoration: none;
    }

        .see-all:hover {
            text-decoration: underline;
        }

    .category-scroll {
        display: flex;
        gap: 10px;
        overflow-x: auto;
        padding-bottom: 8px;
        margin-bottom: 24px;
        scrollbar-width: none;
    }

        .category-scroll::-webkit-scrollbar {
            display: none;
        }

    .cat-pill {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 5px;
        min-width: 76px;
        background: var(--card-bg);
        border-radius: 14px;
        padding: 12px 8px;
        cursor: pointer;
        box-shadow: var(--shadow);
        transition: all 0.2s;
        text-decoration: none;
        border: 2px solid transparent;
        flex-shrink: 0;
    }

        .cat-pill:hover {
            transform: translateY(-4px);
            border-color: var(--primary);
        }

    .cat-icon {
        font-size: 1.5rem;
    }

    .cat-name {
        font-size: 0.72rem;
        font-weight: 600;
        color: var(--text);
    }

    .restaurant-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill,minmax(250px,1fr));
        gap: 18px;
        margin-bottom: 30px;
    }

    .r-card {
        background: var(--card-bg);
        border-radius: 16px;
        overflow: hidden;
        box-shadow: var(--shadow);
        transition: transform 0.25s, box-shadow 0.25s;
        text-decoration: none;
        color: inherit;
        display: block;
    }

        .r-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 32px rgba(0,0,0,0.12);
            color: inherit;
        }

    .r-card-img {
        height: 130px;
        background: linear-gradient( 135deg,#f4f6fb,#e8ecf8);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3.5rem;
        position: relative;
        overflow: hidden;
    }

        .r-card-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .r-tag {
        position: absolute;
        top: 8px;
        left: 8px;
        background: var(--primary);
        color: #fff;
        border-radius: 7px;
        padding: 2px 9px;
        font-size: 0.68rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.4px;
    }

        .r-tag.new-tag {
            background: #339af0;
        }

        .r-tag.trend-tag {
            background: #f59f00;
        }

    .r-closed-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,0.45);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .r-closed-badge {
        background: #fff;
        color: #555;
        border-radius: 8px;
        padding: 4px 12px;
        font-size: 0.75rem;
        font-weight: 700;
    }

    .fav-btn {
        position: absolute;
        bottom: 8px;
        right: 8px;
        background: rgba(255,255,255,0.92);
        border: none;
        border-radius: 50%;
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.95rem;
        cursor: pointer;
        box-shadow: 0 2px 8px rgba(0,0,0,0.15);
        transition: transform 0.2s;
        z-index: 2;
    }

        .fav-btn:hover {
            transform: scale(1.2);
        }

    .r-body {
        padding: 13px 15px;
    }

    .r-name {
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 3px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .r-cuisine {
        font-size: 0.78rem;
        color: var(--muted);
        margin-bottom: 8px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .r-meta {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 0.78rem;
        color: var(--muted);
    }

    .r-rating {
        color: #f59f00;
        font-weight: 700;
    }

    .search-result-bar {
        background: #fff5f5;
        border: 1.5px solid #ffc9c9;
        border-radius: 12px;
        padding: 11px 16px;
        margin-bottom: 18px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

        .search-result-bar span {
            font-size: 0.88rem;
            color: var(--text);
        }

    .clear-search {
        color: var(--primary);
        font-size: 0.83rem;
        font-weight: 600;
        text-decoration: none;
    }

        .clear-search:hover {
            text-decoration: underline;
        }

    .no-results {
        text-align: center;
        padding: 60px 20px;
        color: var(--muted);
    }

        .no-results .big-icon {
            font-size: 4rem;
            margin-bottom: 12px;
        }

        .no-results h5 {
            font-weight: 600;
            color: var(--text);
        }
    /* Coupon styles */
    .coupon-scroll {
        display: flex;
        gap: 12px;
        overflow-x: auto;
        padding-bottom: 8px;
        scrollbar-width: none;
    }

        .coupon-scroll::-webkit-scrollbar {
            display: none;
        }

    .coupon-card {
        flex-shrink: 0;
        width: 240px;
        border-radius: 16px;
        padding: 18px 20px;
        color: #fff;
        position: relative;
        overflow: hidden;
    }

    .coupon-deco {
        position: absolute;
        top: -20px;
        right: -20px;
        width: 80px;
        height: 80px;
        background: rgba(255,255,255,0.08);
        border-radius: 50%;
        pointer-events: none;
    }

    .coupon-type-lbl {
        font-size: 0.7rem;
        opacity: 0.8;
        font-weight: 600;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        margin-bottom: 4px;
    }

    .coupon-value {
        font-size: 1.6rem;
        font-weight: 700;
        line-height: 1.1;
        margin-bottom: 4px;
    }

    .coupon-desc {
        font-size: 0.82rem;
        opacity: 0.85;
        margin-bottom: 10px;
        line-height: 1.4;
    }

    .coupon-min {
        font-size: 0.7rem;
        opacity: 0.7;
        margin-bottom: 8px;
    }

    .coupon-code-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: rgba(255,255,255,0.15);
        border: 1.5px dashed rgba(255,255,255,0.5);
        border-radius: 10px;
        padding: 7px 12px;
    }

    .coupon-code-text {
        font-size: 0.88rem;
        font-weight: 700;
        letter-spacing: 1px;
    }

    .coupon-copy-btn {
        background: rgba(255,255,255,0.25);
        border: none;
        border-radius: 6px;
        color: #fff;
        font-size: 0.72rem;
        font-weight: 600;
        padding: 3px 9px;
        cursor: pointer;
        font-family: 'Poppins',sans-serif;
        transition: background 0.2s;
    }

        .coupon-copy-btn:hover {
            background: rgba(255,255,255,0.4);
        }

    .coupon-expiry {
        font-size: 0.7rem;
        opacity: 0.65;
        margin-top: 8px;
    }
</style>

@Html.AntiForgeryToken()

<!-- Page header -->
<div class="d-flex align-items-center
    justify-content-between mb-4">
    <div>
        <div class="page-title">
            @if (!string.IsNullOrEmpty(
                Model.SearchQuery))
            {
                <span>Search Results</span>
            }
            else
            {
                <span>
                    Good @(DateTime.Now.Hour < 12
                                            ? "Morning"
                                            : DateTime.Now.Hour < 17
                                                ? "Afternoon"
                                                : "Evening"),
                    @Model.UserFullName
                    .Split(' ')[0]! 👋
                </span>
            }
        </div>
        <div class="page-subtitle">
            @if (!string.IsNullOrEmpty(
                Model.SearchQuery))
            {
                <span>
                    Results for
                    "@Model.SearchQuery"
                </span>
            }
            else
            {
                <span>
                    What would you like to eat today?
                </span>
            }
        </div>
    </div>
    <div style="font-size:0.83rem;
        color:var(--muted);">
        📍 Chattogram, BD &nbsp;|&nbsp;
        @DateTime.Now.ToString("ddd, MMM d")
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.SearchQuery))
{
    <div class="search-result-bar">
        <span>
            Found
            <strong>
                @Model.Restaurants.Count
            </strong>
            result(s) for
            "<strong>@Model.SearchQuery</strong>"
        </span>
        <a asp-controller="Dashboard"
           asp-action="Index"
           class="clear-search">
            ✕ Clear
        </a>
    </div>
}
else
{
    <!-- Stats -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon"
                 style="background:#fff0f0;">
                🛍️
            </div>
            <div>
                <div class="stat-label">
                    Total Orders
                </div>
                <div class="stat-value">
                    @(ViewBag.StatTotalOrders ?? 0)
                </div>
                <div class="stat-sub">
                    Your orders
                </div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon"
                 style="background:#f0fff4;">
                ❤️
            </div>
            <div>
                <div class="stat-label">Saved</div>
                <div class="stat-value">
                    @favIds.Count
                </div>
                <div class="stat-sub">
                    Favourites
                </div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon"
                 style="background:#fff8e1;">
                🚀
            </div>
            <div>
                <div class="stat-label">
                    Active Orders
                </div>
                <div class="stat-value">
                    @(ViewBag.StatActiveOrders ?? 0)
                </div>
                <div class="stat-sub"
                     style="color:#f59f00;">
                    In progress
                </div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon"
                 style="background:#f0f4ff;">
                💰
            </div>
            <div>
                <div class="stat-label">
                    Total Spent
                </div>
                <div class="stat-value">
                    ৳@string.Format("{0:N0}",
                                            ViewBag.StatTotalSpent ?? 0)
                </div>
                <div class="stat-sub">Lifetime</div>
            </div>
        </div>
    </div>

    <!-- Weather widget -->
    @if (weather != null)
    {
        <div class="weather-grid">
            <div style="background:linear-gradient(
                135deg,#1a1a2e,#16213e);
                border-radius:18px;
                padding:20px 22px;
                color:#fff;
                box-shadow:var(--shadow);
                display:flex;
                align-items:center;
                justify-content:space-between;">
                <div>
                    <div style="font-size:0.76rem;
                        color:rgba(255,255,255,0.55);
                        margin-bottom:4px;">
                        📍 @weather.City
                    </div>
                    <div style="font-size:2.6rem;
                        font-weight:700;
                        line-height:1;">
                        @weather.Temperature°C
                    </div>
                    <div style="font-size:0.85rem;
                        color:rgba(255,255,255,0.8);
                        margin-top:5px;">
                        @weather.Description
                    </div>
                    <div style="display:flex;
                        gap:14px;
                        margin-top:10px;
                        font-size:0.77rem;
                        color:rgba(255,255,255,0.55);">
                        <span>
                            💧 @weather.Humidity%
                        </span>
                        <span>
                            💨 @weather.WindSpeed km/h
                        </span>
                        <span>
                            🌡️ @weather.FeelsLike°C
                        </span>
                    </div>
                </div>
                <div style="font-size:4rem;">
                    @weather.Emoji
                </div>
            </div>
            <div style="background:linear-gradient(
                135deg,
                var(--primary),#c73535);
                border-radius:18px;
                padding:20px 22px;
                color:#fff;
                box-shadow:var(--shadow);
                display:flex;
                flex-direction:column;
                justify-content:center;">
                <div style="font-size:0.72rem;
                    color:rgba(255,255,255,0.7);
                    margin-bottom:5px;
                    font-weight:600;
                    text-transform:uppercase;">
                    Today's Food Suggestion
                </div>
                <div style="font-size:1.2rem;
                    font-weight:700;
                    margin-bottom:7px;">
                    🍽️ @weather.FoodSuggestion
                </div>
                <div style="font-size:0.85rem;
                    color:rgba(255,255,255,0.8);">
                    @weather.SuggestionReason
                </div>
            </div>
        </div>
    }

    <!-- Coupon offers section -->
    @if (coupons.Any())
    {
        <div style="margin-bottom:24px;">
            <div class="section-header">
                <div class="section-title-sm">
                    🏷️ Available Offers
                </div>
                <span style="font-size:0.8rem;
                    color:var(--muted);">
                    @coupons.Count offer(s)
                </span>
            </div>
            <div class="coupon-scroll">
                @foreach (var coup in coupons)
                {
                    int daysLeft = (int)(
                        coup.ExpiryDate -
                        DateTime.Now).TotalDays;

                    string bgGrad =
                        coup.DiscountType == "Percent"
                        ? "linear-gradient(135deg,#1a1a2e,#e84545)"
                        : "linear-gradient(135deg,#1565c0,#339af0)";

                    string discVal =
                        coup.DiscountType == "Percent"
                        ? coup.DiscountValue
                            .ToString("0") + "%"
                        : "৳" + coup.DiscountValue
                            .ToString("N0");

                    <div class="coupon-card"
                         style="background:@bgGrad;">

                        <div class="coupon-deco">
                        </div>

                        <div class="coupon-type-lbl">
                            @(coup.DiscountType ==
                              "Percent"
                                ? "Percentage Off"
                                : "Flat Discount")
                        </div>

                        <div class="coupon-value">
                            @discVal
                            <span style="font-size:
                                0.85rem;
                                font-weight:400;
                                opacity:0.9;">
                                OFF
                            </span>
                        </div>

                        <div class="coupon-desc">
                            @coup.Description
                        </div>

                        @if (coup.MinOrderAmount > 0)
                        {
                            <div class="coupon-min">
                                Min order:
                                ৳@coup.MinOrderAmount
                                .ToString("N0")
                            </div>
                        }

                        <div class="coupon-code-row">
                            <span class="coupon-code-text">
                                @coup.Code
                            </span>
                            <button type="button"
                                    class="coupon-copy-btn"
                                    data-code="@coup.Code"
                                    onclick="copyCoupon(this)">
                                Copy
                            </button>
                        </div>

                        <div class="coupon-expiry">
                            @if (daysLeft <= 1)
                            {
                                <span style="color:#ffcc00;">
                                    ⚠️ Expires today!
                                </span>
                            }
                            else if (daysLeft <= 7)
                            {
                                <span style="color:#ffcc00;">
                                    ⏰ @daysLeft days left
                                </span>
                            }
                            else
                            {
                                <span>
                                    Valid till
                                    @coup.ExpiryDate
                                    .ToString(
                                    "dd MMM yyyy")
                                </span>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    <!-- Hero banner -->
    <div class="hero-banner mb-4">
        <div>
            <div class="hero-title">
                Free delivery on<br />
                your first order! 🎉
            </div>
            <div class="hero-sub">
                Use code
                <strong>HUNGRY1ST</strong>
                at checkout
            </div>
            <a href="#allRestaurants"
               class="hero-btn">
                Order Now
            </a>
        </div>
        <div class="hero-emoji">🍔</div>
    </div>

    <!-- Categories -->
    <div class="section-header">
        <div class="section-title-sm">
            🍽️ Browse by Category
        </div>
    </div>
    <div class="category-scroll">
        @foreach (var cat in Model.Categories)
        {
            <a asp-controller="Dashboard"
               asp-action="Index"
               asp-route-search="@cat.Name"
               class="cat-pill">
                <span class="cat-icon">
                    @cat.Icon
                </span>
                <span class="cat-name">
                    @cat.Name
                </span>
            </a>
        }
    </div>

    <!-- Featured restaurants -->
    @if (Model.FeaturedRestaurants.Any())
    {
        <div class="section-header">
            <div class="section-title-sm">
                🔥 Popular Near You
            </div>
            <a href="#allRestaurants"
               class="see-all">
                See all →
            </a>
        </div>
        <div class="restaurant-grid mb-4">
            @foreach (var r in
                Model.FeaturedRestaurants)
            {
                bool isFav =
                    favIds.Contains(
                        r.RestaurantId);
                <a asp-controller="Order"
                   asp-action="Menu"
                   asp-route-id="@r.RestaurantId"
                   class="r-card">
                    <div class="r-card-img">
                        @if (!string.IsNullOrEmpty(
                            r.ImageUrl) &&
                            r.ImageUrl.StartsWith("/"))
                        {
                            <img src="@r.ImageUrl"
                                 alt="@r.Name" />
                        }
                        else
                        {
                            <span>@r.ImageUrl</span>
                        }
                        @if (!string.IsNullOrEmpty(
                            r.Tag))
                        {
                            <span class="r-tag @(
                                  r.Tag == "New"
                                      ? "new-tag"
                                  : r.Tag == "Trending"
                                      ? "trend-tag"
                                  : "")">
                                @r.Tag
                            </span>
                        }
                        @if (!r.IsOpen)
                        {
                            <div class="r-closed-overlay">
                                <span class="r-closed-badge">
                                    Closed
                                </span>
                            </div>
                        }
                        <button type="button"
                                class="fav-btn"
                                data-id="@r.RestaurantId"
                                data-name="@r.Name"
                                data-cuisine="@r.Cuisine"
                                data-icon="@r.ImageUrl"
                                onclick="event
                            .preventDefault();
                            toggleFav(this)">
                            @(isFav ? "❤️" : "🤍")
                        </button>
                    </div>
                    <div class="r-body">
                        <div class="r-name">
                            @r.Name
                        </div>
                        <div class="r-cuisine">
                            @r.Cuisine &bull;
                            @r.Address
                        </div>
                        <div class="r-meta">
                            <span class="r-rating">
                                ⭐ @r.Rating
                            </span>
                            <span>
                                🕐 @r.DeliveryTime min
                            </span>
                            <span>
                                ৳@r.DeliveryFee
                            </span>
                        </div>
                    </div>
                </a>
            }
        </div>
    }
}

<!-- All restaurants -->
<div class="section-header"
     id="allRestaurants">
    <div class="section-title-sm">
        @(string.IsNullOrEmpty(Model.SearchQuery)
            ? "🏪 All Restaurants"
            : "🔍 Search Results")
    </div>
    <span style="font-size:0.8rem;
        color:var(--muted);">
        @Model.Restaurants.Count restaurant(s)
    </span>
</div>

@if (!Model.Restaurants.Any())
{
    <div class="no-results">
        <div class="big-icon">🍽️</div>
        <h5>No restaurants found</h5>
        <p>Try a different search term.</p>
        <a asp-controller="Dashboard"
           asp-action="Index"
           style="background:var(--primary);
            color:#fff;
            border-radius:12px;
            padding:10px 24px;
            font-weight:700;
            text-decoration:none;
            display:inline-block;
            margin-top:14px;">
            Browse All
        </a>
    </div>
}
else
{
    <div class="restaurant-grid">
        @foreach (var r in Model.Restaurants)
        {
            bool isFav =
                favIds.Contains(r.RestaurantId);
            <a asp-controller="Order"
               asp-action="Menu"
               asp-route-id="@r.RestaurantId"
               class="r-card">
                <div class="r-card-img">
                    @if (!string.IsNullOrEmpty(
                        r.ImageUrl) &&
                        r.ImageUrl.StartsWith("/"))
                    {
                        <img src="@r.ImageUrl"
                             alt="@r.Name" />
                    }
                    else
                    {
                        <span>@r.ImageUrl</span>
                    }
                    @if (!string.IsNullOrEmpty(
                        r.Tag))
                    {
                        <span class="r-tag @(
                              r.Tag == "New"
                                  ? "new-tag"
                              : r.Tag == "Trending"
                                  ? "trend-tag"
                              : "")">
                            @r.Tag
                        </span>
                    }
                    @if (!r.IsOpen)
                    {
                        <div class="r-closed-overlay">
                            <span class="r-closed-badge">
                                Closed
                            </span>
                        </div>
                    }
                    <button type="button"
                            class="fav-btn"
                            data-id="@r.RestaurantId"
                            data-name="@r.Name"
                            data-cuisine="@r.Cuisine"
                            data-icon="@r.ImageUrl"
                            onclick="event
                        .preventDefault();
                        toggleFav(this)">
                        @(isFav ? "❤️" : "🤍")
                    </button>
                </div>
                <div class="r-body">
                    <div class="r-name">@r.Name</div>
                    <div class="r-cuisine">
                        @r.Cuisine &bull; @r.Address
                    </div>
                    <div class="r-meta">
                        <span class="r-rating">
                            ⭐ @r.Rating
                        </span>
                        <span>
                            🕐 @r.DeliveryTime min
                        </span>
                        <span>
                            ৳@r.DeliveryFee delivery
                        </span>
                    </div>
                </div>
            </a>
        }
    </div>
}

@section Scripts {
    <script>
        // ── Copy coupon code ──────────────────────
        function copyCoupon(btn) {
            var code = btn.getAttribute('data-code');
            if (!code) return;

            navigator.clipboard.writeText(code)
                .then(function() {
                    btn.textContent = 'Copied!';
                    btn.style.background =
                        'rgba(255,255,255,0.45)';
                    setTimeout(function() {
                        btn.textContent = 'Copy';
                        btn.style.background =
                            'rgba(255,255,255,0.25)';
                    }, 2000);
                })
                .catch(function() {
                    btn.textContent = 'Done';
                });
        }

        // ── Toggle favourite ──────────────────────
        function toggleFav(btn) {
            var id      = btn.dataset.id;
            var name    = btn.dataset.name;
            var cuisine = btn.dataset.cuisine;
            var icon    = btn.dataset.icon;

            var tokenEl = document.querySelector(
                'input[name=' +
                '"__RequestVerificationToken"]');
            if (!tokenEl) return;
            var token = tokenEl.value;

            fetch('/Dashboard/ToggleFavourite', {
                method: 'POST',
                headers: {
                    'Content-Type':
                        'application/x-www-form-urlencoded'
                },
                body:
                    'restaurantId=' + id +
                    '&restaurantName=' +
                    encodeURIComponent(name) +
                    '&restaurantCuisine=' +
                    encodeURIComponent(cuisine) +
                    '&restaurantIcon=' +
                    encodeURIComponent(icon) +
                    '&__RequestVerificationToken=' +
                    encodeURIComponent(token)
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.success) {
                    btn.textContent =
                        data.isFavourite
                            ? '❤️' : '🤍';
                    btn.style.transform =
                        'scale(1.3)';
                    setTimeout(function() {
                        btn.style.transform =
                            'scale(1)';
                    }, 300);
                }
            })
            .catch(function(err) {
                console.error('Fav error:', err);
            });
        }
    </script>
}