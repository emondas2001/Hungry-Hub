@model HungryHub.Models.ChangePasswordViewModel
@{
    ViewData["Title"] = "Settings";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<style>
    .settings-grid {
        display:grid;
        grid-template-columns:1fr 1fr;
        gap:24px;
        align-items:start;
    }
    @@media(max-width:768px){ .settings-grid{ grid-template-columns:1fr; } }

    .settings-card {
        background:#fff;
        border-radius:20px;
        box-shadow:var(--shadow);
        padding:28px;
    }

    .settings-card h5 {
        font-size:1rem;
        font-weight:700;
        margin-bottom:20px;
        padding-bottom:12px;
        border-bottom:2px solid var(--border);
        color:var(--text);
    }

    .form-label {
        font-weight:500;
        font-size:0.88rem;
        color:#444;
    }

    .form-control {
        border-radius:10px;
        border:1.5px solid var(--border);
        padding:10px 14px;
        font-size:0.9rem;
        width:100%;
        transition:border-color .2s;
        font-family:'Poppins',sans-serif;
    }

    .form-control:focus {
        outline:none;
        border-color:var(--primary);
        box-shadow:0 0 0 3px rgba(232,69,69,.1);
    }

    .input-group .form-control { border-right:none; border-radius:10px 0 0 10px; }

    .btn-eye {
        border:1.5px solid var(--border);
        border-left:none;
        border-radius:0 10px 10px 0;
        background:#fff;
        padding:0 14px;
        cursor:pointer;
        transition:color .2s;
        color:#888;
    }

    .btn-eye:hover { color:var(--primary); }

    .btn-save-pw {
        background:var(--primary);
        color:#fff; border:none;
        border-radius:12px;
        padding:12px 28px;
        font-size:0.95rem;
        font-weight:700;
        cursor:pointer;
        transition:background .2s;
        width:100%;
        margin-top:8px;
    }

    .btn-save-pw:hover { background:var(--primary-dk); }

    .info-row {
        display:flex;
        justify-content:space-between;
        align-items:center;
        padding:14px 0;
        border-bottom:1px solid var(--border);
        font-size:0.9rem;
    }

    .info-row:last-child { border-bottom:none; }
    .info-row .lbl { color:var(--muted); font-size:0.85rem; }
    .info-row .val { font-weight:600; color:var(--text); }

    .danger-zone {
        background:#fff;
        border-radius:20px;
        box-shadow:var(--shadow);
        padding:28px;
        border:1.5px solid #fde8e8;
        margin-top:24px;
    }

    .danger-zone h5 {
        color:#c62828;
        font-size:1rem;
        font-weight:700;
        margin-bottom:16px;
    }

    .btn-danger-action {
        background:#fdecea;
        border:1.5px solid #f5c6c6;
        border-radius:10px;
        padding:10px 20px;
        color:#c62828;
        font-weight:600;
        font-size:0.85rem;
        cursor:pointer;
        transition:all .2s;
        text-decoration:none;
        display:inline-block;
    }

    .btn-danger-action:hover {
        background:#c62828;
        color:#fff;
        border-color:#c62828;
    }
</style>

<div class="mb-4">
    <div class="page-title">⚙️ Settings</div>
    <div class="page-subtitle">Manage your account preferences and security</div>
</div>

@if (ViewBag.SuccessMessage != null)
{
    <div class="alert alert-success alert-dismissible fade show"
         style="border-radius:12px; border:none; margin-bottom:20px;">
        ✅ @ViewBag.SuccessMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger alert-dismissible fade show"
         style="border-radius:12px; border:none; margin-bottom:20px;">
        ⚠️ @ViewBag.Error
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="settings-grid">

    <!-- Change Password -->
    <div class="settings-card">
        <h5>🔐 Change Password</h5>

        <form asp-controller="Dashboard" asp-action="Settings" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label asp-for="CurrentPassword" class="form-label">Current Password</label>
                <div class="input-group">
                    <input asp-for="CurrentPassword" type="password"
                           class="form-control" id="currPw"
                           placeholder="Enter current password"/>
                    <button type="button" class="btn-eye"
                            onclick="togglePw('currPw',this)">👁</button>
                </div>
                <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="NewPassword" class="form-label">New Password</label>
                <div class="input-group">
                    <input asp-for="NewPassword" type="password"
                           class="form-control" id="newPw"
                           placeholder="Min. 6 characters"/>
                    <button type="button" class="btn-eye"
                            onclick="togglePw('newPw',this)">👁</button>
                </div>
                <span asp-validation-for="NewPassword" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="ConfirmNewPassword" class="form-label">
                    Confirm New Password
                </label>
                <div class="input-group">
                    <input asp-for="ConfirmNewPassword" type="password"
                           class="form-control" id="confPw"
                           placeholder="Repeat new password"/>
                    <button type="button" class="btn-eye"
                            onclick="togglePw('confPw',this)">👁</button>
                </div>
                <span asp-validation-for="ConfirmNewPassword"
                      class="text-danger small"></span>
            </div>

            <button type="submit" class="btn-save-pw">
                🔒 Update Password
            </button>
        </form>
    </div>

    <!-- Account Info -->
    <div class="settings-card">
        <h5>ℹ️ Account Information</h5>

        <div class="info-row">
            <span class="lbl">Full Name</span>
            <span class="val">@ViewBag.UserFullName</span>
        </div>
        <div class="info-row">
            <span class="lbl">Email</span>
            <span class="val">@ViewBag.UserEmail</span>
        </div>
        <div class="info-row">
            <span class="lbl">Session Status</span>
            <span class="val" style="color:#1d7044;">🟢 Active</span>
        </div>
        <div class="info-row">
            <span class="lbl">Session Timeout</span>
            <span class="val">30 minutes</span>
        </div>
        <div class="info-row">
            <span class="lbl">Data Export</span>
            <a href="/Dashboard/DownloadExcel" class="val"
               style="color:var(--primary); text-decoration:none;">
                📊 Download Excel
            </a>
        </div>
        <div class="info-row">
            <span class="lbl">Edit Profile</span>
            <a href="/Dashboard/Profile" class="val"
               style="color:var(--primary); text-decoration:none;">
                ✏️ Go to Profile
            </a>
        </div>
    </div>

</div>

<!-- Danger Zone -->
<div class="danger-zone">
    <h5>⚠️ Danger Zone</h5>
    <p style="font-size:0.88rem; color:var(--muted); margin-bottom:16px;">
        These actions are permanent and cannot be undone.
    </p>
    <div style="display:flex; gap:12px; flex-wrap:wrap;">
        <a href="/Account/Logout" class="btn-danger-action">
            🚪 Logout of Account
        </a>
    </div>
</div>

@section Scripts {
<script>
    function togglePw(id, btn) {
        const input = document.getElementById(id);
        input.type  = input.type === 'password' ? 'text' : 'password';
        btn.textContent = input.type === 'password' ? '👁' : '🙈';
    }
</script>
}