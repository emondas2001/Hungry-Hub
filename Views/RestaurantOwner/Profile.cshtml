@using HungryHub.Models
@{
    ViewData["Title"] = "Restaurant Profile";
    Layout =
        "~/Views/Shared/_OwnerLayout.cshtml";

    RestaurantDb? rest =
        ViewBag.Restaurant as RestaurantDb;

    IEnumerable<RestaurantHours> hours =
        ViewBag.Hours
        as IEnumerable<RestaurantHours>
        ?? Enumerable.Empty<RestaurantHours>();
}

@if (ViewBag.SuccessMessage != null)
{
    <div class="alert alert-success
        alert-dismissible fade show"
         style="border-radius:10px;
        border:none;
        margin-bottom:16px;">
        @ViewBag.SuccessMessage
        <button type="button" class="btn-close"
                data-bs-dismiss="alert">
        </button>
    </div>
}
@if (ViewBag.Error != null)
{
    <div class="alert alert-danger
        alert-dismissible fade show"
         style="border-radius:10px;
        border:none;
        margin-bottom:16px;">
        @ViewBag.Error
        <button type="button" class="btn-close"
                data-bs-dismiss="alert">
        </button>
    </div>
}

<div class="page-heading">
    Restaurant Profile
</div>
<div class="page-sub">
    Update your restaurant info and
    opening hours
</div>

<!-- Profile update -->
<div class="owner-card">
    <h5>🏪 Restaurant Info</h5>
    <form asp-controller="RestaurantOwner"
          asp-action="UpdateProfile"
          method="post"
          enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <div class="row g-3">

            <div class="col-md-4">
                <label class="form-label">
                    Restaurant Name
                </label>
                <input type="text"
                       class="form-control"
                       value="@rest?.Name"
                       disabled
                       style="background:#f4f6fb;" />
                <div style="font-size:0.72rem;
                    color:var(--muted);
                    margin-top:3px;">
                    Name can only be changed by Admin
                </div>
            </div>

            <div class="col-md-4">
                <label class="form-label">
                    Phone *
                </label>
                <input type="text"
                       name="phone"
                       class="form-control"
                       value="@rest?.Phone"
                       placeholder="+880..."
                       required />
            </div>

            <div class="col-md-4">
                <label class="form-label">
                    Address *
                </label>
                <input type="text"
                       name="address"
                       class="form-control"
                       value="@rest?.Address"
                       required />
            </div>

            <div class="col-md-4">
                <label class="form-label">
                    Restaurant Logo / Photo
                </label>
                @if (!string.IsNullOrEmpty(
                    rest?.ImagePath))
                {
                    <img src="@rest.ImagePath"
                         style="width:100%;
                    height:80px;
                    object-fit:cover;
                    border-radius:10px;
                    margin-bottom:6px;
                    border:1px solid
                    var(--border);" />
                }
                <div class="img-upload-wrap">
                    <input type="file"
                           name="restaurantImage"
                           accept="image/*"
                           onchange="previewImg(
                    this,
                    'restPrev',
                    'restLbl')" />
                    <img id="restPrev"
                         style="display:none;
                    width:100%;
                    height:60px;
                    object-fit:cover;
                    border-radius:8px;
                    margin-bottom:4px;"
                         src="" alt="" />
                    <div id="restLbl"
                         class="img-upload-label">
                        <div style="font-size:1.2rem;">
                            📷
                        </div>
                        <div style="font-size:0.75rem;
                            margin-top:2px;">
                            Click to update photo
                        </div>
                        <div style="font-size:0.68rem;
                            color:#bbb;">
                            Auto-resized 400×400
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-8">
                <label class="form-label">
                    Description
                </label>
                <textarea name="description"
                          class="form-control"
                          rows="4"
                          placeholder="Describe your restaurant...">@rest?.Description</textarea>
            </div>

            <div class="col-12">
                <button type="submit"
                        class="btn-primary-o">
                    Save Profile
                </button>
            </div>

        </div>
    </form>
</div>

<!-- Opening hours -->
<div class="owner-card">
    <h5>🕐 Opening Hours</h5>
    <form asp-controller="RestaurantOwner"
          asp-action="SaveHours"
          method="post">
        @Html.AntiForgeryToken()

        @foreach (var h in hours)
        {
            string openVal =
                h.OpenTime.HasValue
                    ? h.OpenTime.Value
                        .ToString("HH:mm")
                    : "09:00";

            string closeVal =
                h.CloseTime.HasValue
                    ? h.CloseTime.Value
                        .ToString("HH:mm")
                    : "23:00";

            string wrapStyle =
                h.IsClosed
                    ? "opacity:0.3;pointer-events:none;"
                    : "";

            <div style="display:flex;
                align-items:center;
                gap:16px;
                padding:11px 0;
                border-bottom:1px solid
                var(--border);
                flex-wrap:wrap;">

                <input type="hidden"
                       name="hoursIds"
                       value="@h.HoursId" />

                <!-- Day label -->
                <div style="width:90px;
                    font-weight:700;
                    font-size:0.9rem;">
                    @h.DayName
                </div>

                <!-- Closed checkbox -->
                <div style="display:flex;
                    align-items:center;
                    gap:6px;">
                    <input type="checkbox"
                           name="isCloseds"
                           value="true"
                           id="cl_@h.HoursId"
                    @(h.IsClosed
                               ? "checked" : "")
                           onchange="toggleHours(
                    this,
                    'tw_@h.HoursId')"
                           style="width:16px;
                    height:16px;
                    accent-color:
                    #e84545;
                    cursor:pointer;" />
                    <label for="cl_@h.HoursId"
                           style="font-size:0.82rem;
                        color:var(--muted);
                        cursor:pointer;">
                        Closed
                    </label>
                </div>

                <!-- Time inputs -->
                <div id="tw_@h.HoursId"
                     style="display:flex;
                    align-items:center;
                    gap:8px;
                    @wrapStyle">
                    <input type="time"
                           name="openTimes"
                           value="@openVal"
                           class="form-control"
                           style="width:120px;" />
                    <span style="color:var(--muted);
                        font-size:0.85rem;">
                        to
                    </span>
                    <input type="time"
                           name="closeTimes"
                           value="@closeVal"
                           class="form-control"
                           style="width:120px;" />
                </div>

            </div>
        }

        <div style="margin-top:16px;">
            <button type="submit"
                    class="btn-primary-o">
                Save Hours
            </button>
        </div>
    </form>
</div>

<!-- Change password -->
<div class="owner-card">
    <h5>🔐 Change Password</h5>
    <form asp-controller="RestaurantOwner"
          asp-action="ChangePassword"
          method="post">
        @Html.AntiForgeryToken()
        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label">
                    Current Password
                </label>
                <input type="password"
                       name="currentPassword"
                       class="form-control"
                       required />
            </div>
            <div class="col-md-4">
                <label class="form-label">
                    New Password
                </label>
                <input type="password"
                       name="newPassword"
                       class="form-control"
                       minlength="6"
                       required />
            </div>
            <div class="col-md-4"
                 style="display:flex;
                align-items:flex-end;">
                <button type="submit"
                        class="btn-primary-o"
                        style="width:100%;">
                    Change Password
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        function toggleHours(cb, wrapId) {
            var wrap =
                document.getElementById(wrapId);
            if (!wrap) return;
            if (cb.checked) {
                wrap.style.opacity = '0.3';
                wrap.style.pointerEvents = 'none';
            } else {
                wrap.style.opacity = '1';
                wrap.style.pointerEvents = 'auto';
            }
        }

        function previewImg(
            input, previewId, labelId) {
            var preview =
                document.getElementById(previewId);
            var label =
                document.getElementById(labelId);
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function(e) {
                    preview.src = e.target.result;
                    preview.style.display = 'block';
                    if (label)
                        label.style.display = 'none';
                };
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}