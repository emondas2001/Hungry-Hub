@model HungryHub.Models.OwnerLoginViewModel
@{
    ViewData["Title"] = "Restaurant Login";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport"
          content="width=device-width,
    initial-scale=1" />
    <title>Restaurant Portal — HungryHub</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
          rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap"
          rel="stylesheet" />
    <style>
            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            body {
                font-family: 'Poppins',sans-serif;
                background: linear-gradient( 135deg,#1a1a2e 0%,#16213e 100%);
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 20px;
            }

            .login-card {
                background: #fff;
                border-radius: 24px;
                padding: 40px 36px;
                width: 100%;
                max-width: 420px;
                box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            }

            .brand {
                text-align: center;
                margin-bottom: 28px;
            }

            .brand-icon {
                font-size: 2.8rem;
                margin-bottom: 8px;
            }

            .brand-title {
                font-size: 1.3rem;
                font-weight: 700;
                color: #1a1a2e;
            }

            .brand-sub {
                font-size: 0.83rem;
                color: #888;
                margin-top: 4px;
            }

            .form-label {
                font-size: 0.85rem;
                font-weight: 600;
                color: #444;
            }

            .form-control {
                border-radius: 10px;
                border: 1.5px solid #e0e0e0;
                padding: 11px 14px;
                font-size: 0.9rem;
                font-family: 'Poppins',sans-serif;
                transition: border-color 0.2s;
            }

                .form-control:focus {
                    border-color: #e84545;
                    box-shadow: 0 0 0 3px rgba(232,69,69,0.1);
                    outline: none;
                }

            .btn-login {
                background: linear-gradient( 135deg,#e84545,#c73535);
                color: #fff;
                border: none;
                border-radius: 12px;
                padding: 13px;
                font-size: 0.95rem;
                font-weight: 700;
                width: 100%;
                cursor: pointer;
                font-family: 'Poppins',sans-serif;
                transition: opacity 0.2s;
            }

                .btn-login:hover {
                    opacity: 0.9;
                }

            .error-box {
                background: #fdecea;
                border: 1px solid #f5c6c6;
                border-radius: 10px;
                padding: 10px 14px;
                font-size: 0.85rem;
                color: #c62828;
                margin-bottom: 16px;
            }

            .success-box {
                background: #e8f9ee;
                border: 1px solid #c3e6cb;
                border-radius: 10px;
                padding: 10px 14px;
                font-size: 0.85rem;
                color: #1d7044;
                margin-bottom: 16px;
            }

            .back-link {
                text-align: center;
                margin-top: 20px;
                font-size: 0.82rem;
                color: #888;
            }

                .back-link a {
                    color: #e84545;
                    font-weight: 600;
                    text-decoration: none;
                }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="brand">
            <div class="brand-icon">🍽️</div>
            <div class="brand-title">
                Restaurant Portal
            </div>
            <div class="brand-sub">
                HungryHub — Partner Login
            </div>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="error-box">
                @ViewBag.Error
            </div>
        }
        @if (ViewBag.SuccessMessage != null)
        {
            <div class="success-box">
                @ViewBag.SuccessMessage
            </div>
        }

        <form asp-controller="RestaurantOwner"
              asp-action="Login"
              method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label class="form-label">
                    Email Address
                </label>
                <input asp-for="Email"
                       class="form-control"
                       placeholder="owner@restaurant.com"
                       autocomplete="email" />
                <span asp-validation-for="Email"
                      class="text-danger"
                      style="font-size:0.8rem;">
                </span>
            </div>

            <div class="mb-4">
                <label class="form-label">
                    Password
                </label>
                <input asp-for="Password"
                       type="password"
                       class="form-control"
                       placeholder="••••••••"
                       autocomplete="current-password" />
                <span asp-validation-for="Password"
                      class="text-danger"
                      style="font-size:0.8rem;">
                </span>
            </div>

            <button type="submit"
                    class="btn-login">
                Login to Dashboard
            </button>
        </form>

        <div class="back-link">
            <a asp-controller="Account"
               asp-action="Login">
                ← Back to HungryHub
            </a>
        </div>
    </div>
</body>
</html>